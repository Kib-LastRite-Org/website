---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import BaseHead from '@/components/BaseHead.astro';
import LandingFooter from '@/components/LandingFooter.astro';
import FormattedDate from '@/components/ui/FormattedDate.astro';
import LandingHeader from '@/components/LandingHeader.astro';
import BackToTopButton from '@/components/ui/BackToTopButton.astro';
import SamplePostBanner from '@/components/ui/SamplePostBanner.astro';

type RelatedPost = CollectionEntry<'posts'>;

interface Props {
  title: string;
  postContent: string;
  date: Date;
  image: string | ImageMetadata;
  imageAlt: string;
  category: string;
  author: string;
  readTime: string;
  tags?: string[];
  draft?: boolean | undefined;
  relatedPosts?: RelatedPost[];
  recentPosts?: RelatedPost[];
}

const {
  title,
  postContent,
  date,
  image,
  imageAlt,
  category,
  author,
  readTime,
  tags,
  draft = false,
  relatedPosts = [],
  recentPosts = [],
} = Astro.props;

const ogImage = typeof image !== 'string' ? image : undefined;
const hasRelated = relatedPosts.length > 0;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={postContent} image={ogImage} />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
		<style>
			.page-container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 2rem;
			}

			.hero-section {
				background: var(--color-surface-container-lowest);
				padding: 3rem 0 0;
			}

			.category-pill {
				display: inline-block;
				padding: 0.5rem 1rem;
				border: 1px solid var(--color-primary);
				background: color-mix(in srgb, var(--color-primary) 10%, transparent);
				color: var(--color-primary);
				border-radius: 999px;
				font-size: 0.875rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.post-title {
				font-family: var(--font-display);
				font-size: clamp(2rem, 5vw, 3rem);
				letter-spacing: -0.02em;
				margin: 1rem 0 1.5rem 0;
				color: var(--color-on-surface);
			}

			.meta-row {
				display: flex;
				gap: 1.5rem;
				flex-wrap: wrap;
				align-items: center;
				margin-bottom: 2rem;
				font-size: 0.95rem;
				color: var(--color-on-surface-variant);
			}

			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.meta-item .material-symbols-outlined {
				font-size: 20px;
			}

			.hero-image-wrapper {
				position: relative;
				aspect-ratio: 2/1;
				border-radius: 1rem;
				overflow: hidden;
				margin: 2rem 0;
				transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.hero-image-wrapper:hover {
				transform: scale(1.02);
			}

			html.light .hero-image-wrapper {
				aspect-ratio: 21/9;
				border: 1px solid var(--color-outline-variant);
			}

			.hero-gradient-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(to top, var(--color-surface), transparent);
				opacity: 0.6;
				pointer-events: none;
			}

			.content-layout {
				display: grid;
				grid-template-columns: 1fr;
				gap: 4rem;
				padding: 3rem 0;
			}

			html.light .content-layout {
				grid-template-columns: 1fr 280px;
			}

			.narrative-container {
				max-width: 680px;
				width: 100%;
			}

			html.dark .narrative-container {
				margin: 0 auto;
			}

			.prose-content {
				font-family: var(--font-atkinson);
				color: var(--color-on-surface);
			}

			.prose-content p {
				margin-bottom: 2em;
				line-height: 1.8;
			}

			html.light .prose-content p:first-of-type::first-letter {
				font-size: 4rem;
				float: left;
				color: var(--color-primary);
				line-height: 0.8;
				margin-right: 0.1em;
			}

			.tags-row {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				margin: 2rem 0;
			}

			.tag-chip {
				display: inline-block;
				padding: 0.5rem 1rem;
				background: var(--color-surface-container-high);
				color: var(--color-on-surface-variant);
				border-radius: 1rem;
				font-size: 0.875rem;
				border: 1px solid var(--color-outline-variant);
			}

			.interaction-bar {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--color-outline-variant);
				font-size: 0.875rem;
				color: var(--color-on-surface-variant);
			}

			.share-label {
				font-weight: 600;
			}

			.icon-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 2rem;
				height: 2rem;
				background: var(--color-surface-container-high);
				border: 1px solid var(--color-outline-variant);
				border-radius: 50%;
				cursor: pointer;
				transition: all 0.2s ease;
				color: var(--color-on-surface);
				text-decoration: none;
			}

			.icon-btn:hover {
				background: var(--color-primary);
				color: var(--color-on-primary);
				border-color: var(--color-primary);
			}

			.sidebar {
				display: none;
				flex-direction: column;
				gap: 1.5rem;
				position: sticky;
				top: 5rem;
			}

			html.light .sidebar {
				display: flex;
			}

			.sidebar-card {
				background: rgba(255, 255, 255, 0.55);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				padding: 1.5rem;
				border-radius: 1rem;
				border: 1px solid var(--color-outline-variant);
			}

			html.dark .sidebar-card {
				background: rgba(38, 57, 43, 0.4);
			}

			.sidebar-card h3 {
				font-size: 1rem;
				margin-bottom: 1rem;
				color: var(--color-on-surface);
			}

			.sidebar-author {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.author-icon {
				font-size: 2.5rem;
				color: var(--color-primary);
			}

			.author-name {
				font-weight: 600;
				color: var(--color-on-surface);
				font-family: var(--font-sans);
			}

			.recent-posts-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.recent-post-link {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
				text-decoration: none;
				color: var(--color-primary);
				font-size: 0.875rem;
				transition: opacity 0.2s ease;
			}

			.recent-post-link:hover {
				opacity: 0.7;
			}

			.recent-post-title {
				font-weight: 600;
				line-height: 1.3;
				color: var(--color-on-surface);
			}

			.recent-post-date {
				font-size: 0.75rem;
				color: var(--color-on-surface-variant);
			}

			.subscribe-form {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.subscribe-form input {
				padding: 0.75rem;
				border: 1px solid var(--color-outline-variant);
				border-radius: 0.5rem;
				background: var(--color-surface-container-low);
				color: var(--color-on-surface);
				font-size: 0.875rem;
			}

			.subscribe-form input::placeholder {
				color: var(--color-on-surface-variant);
			}

			.related-section {
				border-top: 1px solid var(--color-outline-variant);
				padding: 4rem 0;
			}

			.related-section h2 {
				margin-bottom: 2rem;
				font-family: var(--font-display);
				font-size: 1.953em;
			}

			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.5rem;
			}

			@media (max-width: 768px) {
				.related-grid {
					grid-template-columns: 1fr;
				}
			}

			.related-card {
				overflow: hidden;
				border-radius: 0.75rem;
				background: var(--color-surface-container);
				transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				cursor: pointer;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
			}

			.related-card:hover {
				transform: translateY(-4px);
			}

			.related-card-image {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
			}

			.related-card-content {
				padding: 1.5rem;
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.related-card-category {
				display: inline-block;
				padding: 0.25rem 0.75rem;
				background: color-mix(in srgb, var(--color-primary) 10%, transparent);
				color: var(--color-primary);
				border-radius: 999px;
				font-size: 0.75rem;
				font-weight: 600;
				text-transform: uppercase;
				width: fit-content;
			}

			.related-card-title {
				font-family: var(--font-display);
				font-size: 1.1rem;
				color: var(--color-on-surface);
				margin: 0;
			}

			.related-card-excerpt {
				font-size: 0.875rem;
				color: var(--color-on-surface-variant);
				margin: 0;
				flex-grow: 1;
			}

			#scroll-progress {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				background: var(--color-primary);
				z-index: 200;
				width: 0%;
			}

			/* Skeleton styles */
			#post-skeleton {
				display: block;
			}

			#post-skeleton .skeleton-section {
				padding: 3rem 0;
			}

			#post-content {
				opacity: 0;
			}

			@media (max-width: 480px) {
				.page-container {
					padding: 0 1rem;
				}
				.meta-row {
					gap: 1rem;
					font-size: 0.85rem;
				}
			}

			@media (max-width: 375px) {
				.hero-image-wrapper {
					aspect-ratio: 4/3;
				}
			}
		</style>
	</head>

	<body>
		<div id="scroll-progress"></div>
		<LandingHeader />

		<!-- Skeleton loading state -->
		<div id="post-skeleton">
			<div class="page-container skeleton-section">
				<div class="skeleton-block" style="width: 80px; height: 24px; margin-bottom: 1rem; border-radius: 999px;"></div>
				<div class="skeleton-block" style="width: 100%; height: 3rem; margin-bottom: 0.5rem;"></div>
				<div class="skeleton-block" style="width: 90%; height: 2rem; margin-bottom: 1.5rem;"></div>
				<div class="skeleton-meta-row">
					<div class="skeleton-block" style="width: 120px; height: 20px;"></div>
					<div class="skeleton-block" style="width: 120px; height: 20px;"></div>
					<div class="skeleton-block" style="width: 140px; height: 20px;"></div>
				</div>
				<div class="skeleton-block" style="width: 100%; aspect-ratio: 2/1; border-radius: 1rem; margin: 2rem 0;"></div>
			</div>
			<div class="page-container skeleton-section">
				<div class="skeleton-block" style="width: 100%; height: 1rem; margin-bottom: 1rem;"></div>
				<div class="skeleton-block" style="width: 95%; height: 1rem; margin-bottom: 1rem;"></div>
				<div class="skeleton-block" style="width: 90%; height: 1rem; margin-bottom: 2rem;"></div>
				<div class="skeleton-meta-row">
					<div class="skeleton-block" style="width: 60px; height: 20px;"></div>
					<div class="skeleton-block" style="width: 60px; height: 20px;"></div>
					<div class="skeleton-block" style="width: 60px; height: 20px;"></div>
				</div>
			</div>
		</div>

		<!-- Real content -->
		<article id="post-content" style="opacity:0">
			<!-- Hero section -->
			<section class="hero-section reveal" data-delay="1">
				<div class="page-container">
					<div class="category-pill reveal" data-delay="1">{category}</div>
					<h1 class="post-title reveal" data-delay="2">{title}</h1>
					<div class="meta-row reveal" data-delay="3">
						<div class="meta-item">
							<span class="material-symbols-outlined">calendar_today</span>
							<FormattedDate date={date} />
						</div>
						<div class="meta-item">
							<span class="material-symbols-outlined">schedule</span>
							{readTime}
						</div>
						<div class="meta-item">
							<span class="material-symbols-outlined">person</span>
							{author}
						</div>
					</div>
					<div class="hero-image-wrapper reveal" data-delay="4">
						{typeof image === 'string' ? (
							<img src={image} alt={imageAlt} />
						) : (
							<Image src={image} alt={imageAlt} />
						)}
						<div class="hero-gradient-overlay"></div>
					</div>
				</div>
			</section>

			<!-- Content + Sidebar -->
			<div class="page-container content-layout">
				<div class="narrative-container">
					<div class="prose-content reveal" data-delay="5">
						{draft && <SamplePostBanner category={category} />}
						<slot />
					</div>

					{tags && tags.length > 0 && (
						<div class="tags-row reveal" data-delay="6">
							{tags.map((tag) => (
								<span class="tag-chip">{tag}</span>
							))}
						</div>
					)}

					<div class="interaction-bar reveal" data-delay="7">
						<span class="share-label">Share:</span>
						<button
							class="icon-btn"
							id="copy-link-btn"
							title="Copy link"
							aria-label="Copy link to clipboard"
						>
							<span class="material-symbols-outlined">link</span>
						</button>
						<a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="icon-btn" title="Share on Twitter" aria-label="Share on Twitter">
							<span class="material-symbols-outlined">share</span>
						</a>
					</div>
				</div>

				<aside class="sidebar reveal" data-delay="5">
					<!-- Author card -->
					<div class="sidebar-card">
						<div class="sidebar-author">
							<span class="author-icon material-symbols-outlined">person</span>
							<div class="author-name">{author}</div>
						</div>
					</div>

					<!-- Recent posts card -->
					{recentPosts.length > 0 && (
						<div class="sidebar-card">
							<h3>Recent Journal</h3>
							<div class="recent-posts-list">
								{recentPosts.map((post) => (
									<a href={`/blog/${post.id}`} class="recent-post-link">
										<span class="recent-post-title">{post.data.title}</span>
										<span class="recent-post-date">
											<FormattedDate date={post.data.date} />
										</span>
									</a>
								))}
							</div>
						</div>
					)}

					<!-- Subscribe card -->
					<div class="sidebar-card">
						<h3>Subscribe</h3>
						<form class="subscribe-form">
							<input type="email" placeholder="Your email" required />
							<button type="submit" class="btn btn-primary">Subscribe</button>
						</form>
					</div>
				</aside>
			</div>

			<!-- Related posts section -->
			{hasRelated && (
				<section class="related-section reveal" data-delay="8">
					<div class="page-container">
						<h2>Related Stories</h2>
						<div class="related-grid">
							{relatedPosts.map((post) => (
								<a href={`/blog/${post.id}`} class="related-card">
									<div style="position: relative; overflow: hidden; aspect-ratio: 16/9;">
										{typeof post.data.image === 'string' ? (
											<img src={post.data.image} alt={post.data.imageAlt} class="related-card-image" />
										) : (
											<Image src={post.data.image} alt={post.data.imageAlt} class="related-card-image" />
										)}
									</div>
									<div class="related-card-content">
										<div class="related-card-category">{post.data.category}</div>
										<h3 class="related-card-title">{post.data.title}</h3>
										<p class="related-card-excerpt">{post.data.postContent}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}
		</article>

		<LandingFooter />
		<BackToTopButton />

		<script>
			// Skeleton → content reveal
			document.addEventListener('DOMContentLoaded', () => {
				const skeleton = document.getElementById('post-skeleton');
				const content = document.getElementById('post-content');

				if (skeleton) {
					skeleton.style.display = 'none';
				}

				if (content) {
					content.style.transition = 'opacity 0.6s cubic-bezier(0.4,0,0.2,1)';
					content.style.opacity = '1';
				}
			});

			// Scroll progress bar
			const bar = document.getElementById('scroll-progress');
			if (bar) {
				window.addEventListener(
					'scroll',
					() => {
						const pct =
							(window.scrollY /
								(document.documentElement.scrollHeight -
									window.innerHeight)) *
							100;
						bar.style.setProperty('width', pct + '%');
					},
					{ passive: true }
				);
			}

			// Copy link button
			const copyBtn = document.getElementById('copy-link-btn');
			if (copyBtn) {
				copyBtn.addEventListener('click', () => {
					navigator.clipboard.writeText(window.location.href);
				});
			}
		</script>
	</body>
</html>
