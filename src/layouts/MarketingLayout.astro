---
import BaseHead from '@/components/BaseHead.astro';
import LandingHeader from '@/components/LandingHeader.astro';
import LandingFooter from '@/components/LandingFooter.astro';
import BackToTopButton from '@/components/ui/BackToTopButton.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <LandingHeader />
    <slot />
    <LandingFooter />
    <BackToTopButton />

    <script>
      import { initComingSoonInterceptor } from '@/scripts/comingSoonInterceptor';
      import { initLastRiteToastInterceptor } from '@/scripts/lastRiteToastInterceptor';

      const initInterceptors = () => {
        initComingSoonInterceptor();
        initLastRiteToastInterceptor();
      };

      // Initialize interceptors when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initInterceptors);
      } else {
        initInterceptors();
      }
    </script>

    <style is:global>
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.2s;
      }
    </style>

  </body>
</html>
