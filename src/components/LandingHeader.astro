---
import ThemeToggle from './ThemeToggle.astro';
---

<header id="landing-header" class="landing-header">
  <nav class="nav-bar" aria-label="Main navigation">
    <a href="/" class="logo" title="LastRite home">LastRite</a>

    <div class="nav-links" id="nav-links">
      <a href="#features">Features</a>
      <a href="#how-it-works">How It Works</a>
      <a href="#testimonials">Testimonials</a>
      <a href="#tributes">Tributes</a>
    </div>

    <div class="nav-actions">
      <ThemeToggle />
      <a href="#how-it-works" class="btn btn-outline btn-sm">Learn More</a>
      <a href="/waitlist" class="btn btn-primary btn-sm">Join Waitlist</a>
    </div>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="mobile-drawer-backdrop" id="mobile-drawer-backdrop" hidden></div>
  <div class="mobile-drawer" id="mobile-drawer" hidden>
    <div class="mobile-drawer-header">
      <ThemeToggle />
      <button
        id="mobile-drawer-close"
        class="mobile-drawer-close"
        aria-label="Close menu"
      >
        ×
      </button>
    </div>
    <nav class="mobile-drawer-content">
      <a href="#features">Features</a>
      <a href="#how-it-works">How It Works</a>
      <a href="#testimonials">Testimonials</a>
      <a href="#tributes">Tributes</a>
      <div class="mobile-drawer-actions">
        <a href="#how-it-works" class="btn btn-outline btn-sm">Learn More</a>
        <a href="/waitlist" class="btn btn-primary btn-sm">Join Waitlist</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .landing-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-outline-variant);
    transition: box-shadow 0.3s ease;
  }

  .landing-header.scrolled {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 64px;
    max-width: 100%;
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .logo:hover {
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    color: var(--color-on-surface);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .nav-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .btn-sm {
    padding: 0.5em 1.1em;
    font-size: 0.875rem;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background: var(--color-on-surface);
    transition: all 0.3s ease;
    border-radius: 2px;
  }

  .hamburger[aria-expanded='true'] span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  .hamburger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded='true'] span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background: var(--color-surface-container);
    border-bottom: 1px solid var(--color-outline-variant);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .mobile-menu[aria-hidden='false'] {
    max-height: 300px;
  }

  .mobile-menu a {
    color: var(--color-on-surface);
    font-weight: 500;
  }

  .mobile-drawer-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 90;
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.3s ease, pointer-events 0.3s ease;
  }

  .mobile-drawer-backdrop[hidden],
  .mobile-drawer-backdrop[aria-hidden='true'] {
    display: none !important;
    opacity: 0;
    pointer-events: none;
  }

  .mobile-drawer {
    position: fixed;
    right: 0;
    top: 0;
    height: 100vh;
    width: 80%;
    max-width: 300px;
    background: var(--color-surface);
    z-index: 100;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }

  .mobile-drawer[hidden] {
    display: none !important;
  }

  .mobile-drawer[aria-hidden='false'] {
    transform: translateX(0);
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .mobile-drawer-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.5rem;
    color: var(--color-on-surface);
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .mobile-drawer-close:hover {
    color: var(--color-primary);
  }

  .mobile-drawer-close:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .mobile-drawer-content {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 1.5rem 1.5rem;
  }

  .mobile-drawer-content a {
    padding: 1rem 0;
    color: var(--color-on-surface);
    font-weight: 500;
    font-size: 1rem;
    border-bottom: 1px solid var(--color-outline-variant);
    transition: color 0.2s ease;
  }

  .mobile-drawer-content a:last-of-type {
    border-bottom: none;
  }

  .mobile-drawer-content a:hover {
    color: var(--color-primary);
  }

  .mobile-drawer-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.5rem;
    margin-top: 1rem;
    border-top: 1px solid var(--color-outline-variant);
  }

  .mobile-drawer-actions .btn {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 720px) {
    .nav-bar {
      padding: 0 1rem;
    }

    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .nav-actions {
      display: none;
    }

    .mobile-drawer {
      display: block;
    }
  }
</style>

<script>
  import { toggleTheme } from '../scripts/theme.js';

  const hamburger = document.getElementById('hamburger');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const mobileDrawerBackdrop = document.getElementById('mobile-drawer-backdrop');
  const header = document.getElementById('landing-header');
  let isDrawerOpen = false;

  // Attach theme toggle listener to all instances (for both desktop and mobile drawer)
  const themeToggleButtons = document.querySelectorAll('.theme-toggle');
  themeToggleButtons.forEach((button) => {
    button.addEventListener('click', toggleTheme);
  });

  const closeDrawer = () => {
    isDrawerOpen = false;
    if (hamburger) hamburger.setAttribute('aria-expanded', 'false');
    if (mobileDrawer) {
      mobileDrawer.setAttribute('hidden', '');
      mobileDrawer.setAttribute('aria-hidden', 'true');
    }
    if (mobileDrawerBackdrop) {
      mobileDrawerBackdrop.setAttribute('hidden', '');
      mobileDrawerBackdrop.setAttribute('aria-hidden', 'true');
    }
  };

  const openDrawer = () => {
    isDrawerOpen = true;
    if (hamburger) hamburger.setAttribute('aria-expanded', 'true');
    if (mobileDrawer) {
      mobileDrawer.removeAttribute('hidden');
      mobileDrawer.setAttribute('aria-hidden', 'false');
    }
    if (mobileDrawerBackdrop) {
      mobileDrawerBackdrop.removeAttribute('hidden');
      mobileDrawerBackdrop.setAttribute('aria-hidden', 'false');
    }
  };

  // Hamburger toggle
  if (hamburger) {
    hamburger.addEventListener('click', () => {
      if (isDrawerOpen) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });
  }

  // Close drawer on link click
  if (mobileDrawer) {
    const drawerLinks = mobileDrawer.querySelectorAll('a');
    drawerLinks.forEach((link) => {
      link.addEventListener('click', closeDrawer);
    });
  }

  // Close drawer on backdrop click
  if (mobileDrawerBackdrop) {
    mobileDrawerBackdrop.addEventListener('click', (e) => {
      if (e.target === mobileDrawerBackdrop) {
        closeDrawer();
      }
    });
  }

  // Close drawer on close button click
  const closeButton = document.getElementById('mobile-drawer-close');
  if (closeButton) {
    closeButton.addEventListener('click', closeDrawer);
  }

  // Scroll effect for header shadow
  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 0) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  }
</script>
