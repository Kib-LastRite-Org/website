---
---

<section class="hero min-h-screen flex flex-col items-center justify-center px-4 pt-16 relative overflow-hidden">
  <!-- Background radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-mint/8 blur-3xl"></div>
  </div>

  <div class="relative max-w-3xl text-center">
    <!-- Eyebrow tag -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-mint/25 bg-mint/8 text-mint text-xs font-semibold tracking-widest uppercase mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-mint inline-block"></span>
      Digital Memorials
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6 text-white leading-tight text-balance">
      Where Life Stories
      <span class="text-mint"> Go On</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-400 mb-10 leading-relaxed max-w-xl mx-auto">
      Create meaningful digital memorials. Share stories, gather condolences, and honor those we've lost.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#features"
        class="px-8 py-4 bg-mint text-dark font-bold rounded-btn hover:bg-mint-light hover:scale-105 active:scale-95 transition-all duration-200 shadow-lg shadow-mint/20"
      >
        Explore Features
      </a>
      <a
        href="#download"
        class="px-8 py-4 border-2 border-orange text-orange font-bold rounded-btn hover:bg-orange hover:text-dark hover:scale-105 active:scale-95 transition-all duration-200"
      >
        Get Started →
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-500 text-xs animate-bounce-slow">
    <span class="tracking-wider uppercase text-[10px]">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, #07190D 0%, #0e2a18 40%, #07190D 100%);
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }
</style>
