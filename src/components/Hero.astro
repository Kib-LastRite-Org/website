---
---

<section class="min-h-screen flex items-center px-4 pt-16 relative overflow-hidden bg-[color:var(--color-background)]">
  <!-- Background radial glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full bg-[color:var(--color-primary)]/8 blur-3xl"></div>
  </div>

  <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-16 max-w-6xl mx-auto w-full">
    <!-- Left column: Copy and CTAs -->
    <div class="flex flex-col justify-center">
      <!-- Eyebrow tag -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[color:var(--color-primary)]/25 bg-[color:var(--color-primary)]/8 text-[color:var(--color-primary)] text-xs font-semibold tracking-widest uppercase mb-8 w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-primary)] inline-block"></span>
        Digital Memorials
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-extrabold mb-6 text-[color:var(--color-on-surface)] leading-tight">
        Where Life Stories
        <span class="text-[color:var(--color-primary)]"> Go On</span>
      </h1>

      <p class="text-lg md:text-xl text-[color:var(--color-on-surface-variant)] mb-10 leading-relaxed max-w-lg">
        Create meaningful digital memorials. Share stories, gather condolences, and honor those we've lost.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#features"
          class="px-8 py-4 bg-[color:var(--color-primary)] text-[color:var(--color-on-primary)] font-bold rounded-btn hover:bg-[color:var(--color-mint-light)] hover:scale-105 active:scale-95 transition-all duration-200 shadow-lg shadow-[color:var(--color-primary)]/20 text-center"
        >
          Explore Features
        </a>
        <a
          href="#download"
          class="px-8 py-4 border-2 border-[color:var(--color-secondary)] text-[color:var(--color-secondary)] font-bold rounded-btn hover:bg-[color:var(--color-secondary)] hover:text-[color:var(--color-on-secondary)] hover:scale-105 active:scale-95 transition-all duration-200 text-center"
        >
          Get Started →
        </a>
      </div>
    </div>

    <!-- Right column: Stats glass-panel -->
    <div class="flex items-center justify-center">
      <div class="glass-panel rounded-xl p-8 w-full max-w-sm">
        <div class="space-y-8">
          <!-- Stat 1 -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined icon-lg text-[color:var(--color-primary)] flex-shrink-0">favorite</span>
            <div>
              <div class="text-3xl font-bold text-[color:var(--color-on-surface)]">10K+</div>
              <div class="text-sm text-[color:var(--color-on-surface-variant)]">Memorials Created</div>
            </div>
          </div>

          <!-- Stat 2 -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined icon-lg text-[color:var(--color-secondary)] flex-shrink-0">public</span>
            <div>
              <div class="text-3xl font-bold text-[color:var(--color-on-surface)]">50+</div>
              <div class="text-sm text-[color:var(--color-on-surface-variant)]">Countries Served</div>
            </div>
          </div>

          <!-- Stat 3 -->
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined icon-lg text-[color:var(--color-primary)] flex-shrink-0">check_circle</span>
            <div>
              <div class="text-3xl font-bold text-[color:var(--color-on-surface)]">100%</div>
              <div class="text-sm text-[color:var(--color-on-surface-variant)]">Free to Start</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[color:var(--color-on-surface-variant)] text-xs animate-bounce-slow">
    <span class="tracking-wider uppercase text-[10px]">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }
</style>
