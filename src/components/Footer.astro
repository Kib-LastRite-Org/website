---
---

<footer class="bg-[color:var(--color-surface-container-lowest)] border-t border-[color:var(--color-outline-variant)]/30 py-14 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="grid md:grid-cols-1 lg:grid-cols-4 gap-10 mb-10">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2 text-[color:var(--color-primary)] font-bold text-lg mb-3 hover:text-[color:var(--color-mint-light)] transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C12 2 7 7 7 13a5 5 0 0 0 10 0C17 7 12 2 12 2Z" fill="currentColor" opacity="0.95"/>
            <rect x="11" y="17" width="2" height="5" rx="1" fill="currentColor" opacity="0.4"/>
          </svg>
          LastRite
        </a>
        <p class="text-[color:var(--color-on-surface-variant)] text-sm leading-relaxed">
          Where life stories go on. Creating meaningful memorials for those we've loved and lost.
        </p>
      </div>

      <!-- Col 2: Product Links -->
      <div>
        <h4 class="text-sm font-semibold text-[color:var(--color-on-surface)] uppercase tracking-widest mb-4">Product</h4>
        <ul class="space-y-2.5 text-sm text-[color:var(--color-on-surface-variant)]">
          <li><a href="#features" class="hover:text-[color:var(--color-primary)] transition-colors">Features</a></li>
          <li><a href="#howitworks" class="hover:text-[color:var(--color-primary)] transition-colors">How It Works</a></li>
          <li><a href="#download" class="hover:text-[color:var(--color-primary)] transition-colors">Get Started</a></li>
        </ul>
      </div>

      <!-- Col 3: Legal & Contact -->
      <div>
        <h4 class="text-sm font-semibold text-[color:var(--color-on-surface)] uppercase tracking-widest mb-4">Legal</h4>
        <ul class="space-y-2.5 text-sm text-[color:var(--color-on-surface-variant)]">
          <li><a href="/privacy" class="hover:text-[color:var(--color-primary)] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-[color:var(--color-primary)] transition-colors">Terms of Service</a></li>
          <li>
            <a href="#" data-coming-soon class="text-[color:var(--color-secondary)] hover:text-[color:var(--color-primary)] transition-colors text-sm font-semibold">
              hello@lastrite.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 4: Newsletter Signup -->
      <div>
        <h4 class="text-sm font-semibold text-[color:var(--color-on-surface)] uppercase tracking-widest mb-4">Stay Updated</h4>
        <p class="text-[color:var(--color-on-surface-variant)] text-sm mb-3">
          Get updates and stories delivered to your inbox.
        </p>
        <div class="flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 px-3 py-2 rounded-btn bg-[color:var(--color-surface-container)] text-[color:var(--color-on-surface)] text-sm placeholder-[color:var(--color-on-surface-variant)] border border-[color:var(--color-outline-variant)] focus:outline-none focus:border-[color:var(--color-primary)] transition-colors"
          />
          <button
            class="px-4 py-2 rounded-btn bg-[color:var(--color-primary)] text-[color:var(--color-on-primary)] font-semibold text-sm hover:opacity-90 transition-opacity active:scale-95"
          >
            Join
          </button>
        </div>
      </div>

    </div>

    <div class="border-t border-[color:var(--color-outline-variant)]/30 pt-8">
      <p class="text-center text-[color:var(--color-on-surface-variant)] text-xs tracking-wide">
        © {new Date().getFullYear()} LastRite. All rights reserved.
      </p>
    </div>

  </div>
</footer>
