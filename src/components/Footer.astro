---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} LastRite. All rights reserved.
	<p style="font-size: 0.9em; margin-top: 0.5em;">The official marketing site built with Astro.</p>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		color: var(--color-on-surface-variant);
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--color-on-surface-variant);
	}
	.social-links a:hover {
		color: var(--color-on-surface);
	}
</style>
