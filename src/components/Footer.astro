<footer class="bg-dark border-t border-mint/10 py-14 px-4">
  <div class="max-w-6xl mx-auto">

    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-flex items-center gap-2 text-mint font-bold text-lg mb-3 hover:text-mint-light transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C12 2 7 7 7 13a5 5 0 0 0 10 0C17 7 12 2 12 2Z" fill="currentColor" opacity="0.95"/>
            <rect x="11" y="17" width="2" height="5" rx="1" fill="currentColor" opacity="0.4"/>
          </svg>
          LastRite
        </a>
        <p class="text-gray-500 text-sm leading-relaxed">
          Where life stories go on. Creating meaningful memorials for those we've loved and lost.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-widest mb-4">Quick Links</h4>
        <ul class="space-y-2.5 text-sm text-gray-500">
          <li><a href="#features" class="hover:text-mint transition-colors">Features</a></li>
          <li><a href="#howitworks" class="hover:text-mint transition-colors">How It Works</a></li>
          <li><a href="#download" class="hover:text-mint transition-colors">Get Started</a></li>
          <li><a href="/privacy" class="hover:text-mint transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-mint transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-widest mb-4">Get In Touch</h4>
        <p class="text-gray-500 text-sm mb-3">
          Questions or feedback? Reach us at:
        </p>
        <a href="#" data-coming-soon class="text-orange hover:text-mint transition-colors text-sm font-semibold">
          hello@lastrite.com
        </a>
      </div>

    </div>

    <div class="border-t border-white/5 pt-8">
      <p class="text-center text-gray-600 text-xs tracking-wide">
        © {new Date().getFullYear()} LastRite. All rights reserved.
      </p>
    </div>

  </div>
</footer>
