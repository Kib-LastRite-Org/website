---
---

<section id="features" class="py-28 px-4 bg-(--color-surface)">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-on-surface">
        Key <span class="text-(--color-primary)">Features</span>
      </h2>
      <p class="text-on-surface-variant max-w-xl mx-auto">
        Everything you need to create, share, and honor a life well-lived.
      </p>
    </div>

    <div class="grid grid-cols-12 gap-4">

      <!-- Feature 1: Obituary (col-span-4) -->
      <div class="col-span-12 md:col-span-6 lg:col-span-4 group bg-(--color-surface-container) rounded-card p-8 hover:scale-[1.02] transition-transform duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0s;">
        <div class="w-12 h-12 rounded-xl bg-(--color-primary)/10 flex items-center justify-center mb-5 group-hover:bg-(--color-primary)/20 transition-colors">
          <span class="material-symbols-outlined icon-md text-(--color-primary)">auto_stories</span>
        </div>
        <h3 class="text-lg font-bold text-(--color-primary) mb-2">Obituary Creation</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Build beautiful, customizable memorial pages that celebrate life and legacy.
        </p>
      </div>

      <!-- Feature 2: Condolences (col-span-8) -->
      <div class="col-span-12 md:col-span-6 lg:col-span-8 group bg-(--color-surface-container-high) rounded-card p-8 hover:scale-[1.02] transition-transform duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.1s;">
        <div class="w-12 h-12 rounded-xl bg-(--color-secondary)/10 flex items-center justify-center mb-5 group-hover:bg-(--color-secondary)/20 transition-colors">
          <span class="material-symbols-outlined icon-md text-(--color-secondary)">sentiment_satisfied</span>
        </div>
        <h3 class="text-lg font-bold text-(--color-secondary) mb-2">Condolences & Memories</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Let loved ones share memories, stories, and words of comfort in one place.
        </p>
      </div>

      <!-- Feature 3: Fundraising (col-span-7) -->
      <div class="col-span-12 md:col-span-7 group bg-(--color-surface-container-high) rounded-card p-8 hover:scale-[1.02] transition-transform duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.2s;">
        <div class="w-12 h-12 rounded-xl bg-(--color-primary)/10 flex items-center justify-center mb-5 group-hover:bg-(--color-primary)/20 transition-colors">
          <span class="material-symbols-outlined icon-md text-(--color-primary)">volunteer_activism</span>
        </div>
        <h3 class="text-lg font-bold text-(--color-primary) mb-2">Fundraising</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Gather support for funeral costs or charitable causes via secure M-Pesa integration.
        </p>
      </div>

      <!-- Feature 4: Responsive (col-span-5) -->
      <div class="col-span-12 md:col-span-5 group bg-(--color-surface-container) rounded-card p-8 hover:scale-[1.02] transition-transform duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.3s;">
        <div class="w-12 h-12 rounded-xl bg-(--color-secondary)/10 flex items-center justify-center mb-5 group-hover:bg-(--color-secondary)/20 transition-colors">
          <span class="material-symbols-outlined icon-md text-(--color-secondary)">devices</span>
        </div>
        <h3 class="text-lg font-bold text-(--color-secondary) mb-2">Web & Mobile</h3>
        <p class="text-on-surface-variant text-sm leading-relaxed">
          Access from any device — works seamlessly on phones, tablets, and desktops.
        </p>
      </div>

    </div>
  </div>
</section>
