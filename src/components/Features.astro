---
---

<section id="features" class="py-28 px-4 bg-dark">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
        Key <span class="text-mint">Features</span>
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Everything you need to create, share, and honor a life well-lived.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Feature 1: Obituary -->
      <div class="group bg-dark-card rounded-card p-8 border border-white/5 hover:border-mint/40 hover:-translate-y-2 hover:shadow-xl hover:shadow-mint/10 transition-all duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0s;">
        <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-5 group-hover:bg-mint/20 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3EB489" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="8" y1="13" x2="16" y2="13"/>
            <line x1="8" y1="17" x2="12" y2="17"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-mint mb-2">Obituary Creation</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Build beautiful, customizable memorial pages that celebrate life and legacy.
        </p>
      </div>

      <!-- Feature 2: Condolences -->
      <div class="group bg-dark-card rounded-card p-8 border border-white/5 hover:border-mint/40 hover:-translate-y-2 hover:shadow-xl hover:shadow-mint/10 transition-all duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.1s;">
        <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-5 group-hover:bg-mint/20 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3EB489" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            <path d="M12 8v.01M8 11h8" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-mint mb-2">Condolences & Memories</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Let loved ones share memories, stories, and words of comfort in one place.
        </p>
      </div>

      <!-- Feature 3: Fundraising -->
      <div class="group bg-dark-card rounded-card p-8 border border-white/5 hover:border-mint/40 hover:-translate-y-2 hover:shadow-xl hover:shadow-mint/10 transition-all duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.2s;">
        <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-5 group-hover:bg-mint/20 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3EB489" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-mint mb-2">Fundraising</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Gather support for funeral costs or charitable causes via secure M-Pesa integration.
        </p>
      </div>

      <!-- Feature 4: Responsive -->
      <div class="group bg-dark-card rounded-card p-8 border border-white/5 hover:border-mint/40 hover:-translate-y-2 hover:shadow-xl hover:shadow-mint/10 transition-all duration-300" style="animation: fadeUp 0.5s ease forwards; animation-delay: 0.3s;">
        <div class="w-12 h-12 rounded-xl bg-mint/10 flex items-center justify-center mb-5 group-hover:bg-mint/20 transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3EB489" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-mint mb-2">Web & Mobile</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Access from any device — works seamlessly on phones, tablets, and desktops.
        </p>
      </div>

    </div>
  </div>
</section>
