---
---

<section id="howitworks" class="py-28 px-4 relative overflow-hidden bg-[color:var(--color-surface-container-lowest)]">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute bottom-0 right-1/4 w-96 h-96 rounded-full bg-[color:var(--color-secondary)]/5 blur-3xl"></div>
  </div>

  <div class="relative max-w-5xl mx-auto">

    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-[color:var(--color-on-surface)]">
        How It <span class="text-[color:var(--color-primary)]">Works</span>
      </h2>
      <p class="text-[color:var(--color-on-surface-variant)] max-w-xl mx-auto">
        Three simple steps to create and share a meaningful memorial.
      </p>
    </div>

    <!-- Steps with connecting line -->
    <div class="relative grid md:grid-cols-3 gap-12 md:gap-8">

      <!-- Connecting line (desktop only) -->
      <div
        class="hidden md:block absolute h-px bg-gradient-to-r from-transparent via-[color:var(--color-primary)]/30 to-transparent top-8 -translate-y-1/2"
        style="left: 16.67%; right: 16.67%;"
        aria-hidden="true"
      ></div>

      <!-- Step 1 -->
      <div class="text-center relative">
        <div class="w-16 h-16 bg-[color:var(--color-primary)] rounded-full flex items-center justify-center mx-auto mb-6 text-[color:var(--color-on-primary)] font-bold text-xl shadow-lg shadow-[color:var(--color-primary)]/30 relative z-10">
          1
        </div>
        <h3 class="text-xl font-bold text-[color:var(--color-primary)] mb-3">Create</h3>
        <p class="text-[color:var(--color-on-surface-variant)] text-sm leading-relaxed">
          Build a beautiful memorial page with photos, stories, and details about your loved one.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="text-center relative">
        <div class="w-16 h-16 bg-[color:var(--color-secondary)] rounded-full flex items-center justify-center mx-auto mb-6 text-[color:var(--color-on-secondary)] font-bold text-xl shadow-lg shadow-[color:var(--color-secondary)]/30 relative z-10">
          2
        </div>
        <h3 class="text-xl font-bold text-[color:var(--color-secondary)] mb-3">Share</h3>
        <p class="text-[color:var(--color-on-surface-variant)] text-sm leading-relaxed">
          Easily share the memorial with family, friends, and community via email or social media.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="text-center relative">
        <div class="w-16 h-16 bg-[color:var(--color-primary)] rounded-full flex items-center justify-center mx-auto mb-6 text-[color:var(--color-on-primary)] font-bold text-xl shadow-lg shadow-[color:var(--color-primary)]/30 relative z-10">
          3
        </div>
        <h3 class="text-xl font-bold text-[color:var(--color-primary)] mb-3">Remember</h3>
        <p class="text-[color:var(--color-on-surface-variant)] text-sm leading-relaxed">
          Gather condolences, memories, and support. Keep the memory alive for years to come.
        </p>
      </div>

    </div>
  </div>
</section>
