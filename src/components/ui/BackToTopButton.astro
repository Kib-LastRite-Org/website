---

<button class="back-to-top" aria-label="Back to top" title="Back to top">
	<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
		<path
			fill="currentColor"
			d="M7 14l5-5 5 5z"
		/>
	</svg>
</button>

<style>
	.back-to-top {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background-color: var(--color-primary);
		color: var(--color-on-primary);
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transform: translateY(20px);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 99;
		box-shadow: 0 4px 12px rgba(105, 219, 173, 0.3);
		font-size: 0;
	}

	.back-to-top.visible {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.back-to-top:hover {
		background-color: var(--color-primary-container);
		color: var(--color-on-primary);
		box-shadow: 0 6px 20px rgba(105, 219, 173, 0.4);
		transform: translateY(-2px);
	}

	.back-to-top:active {
		transform: translateY(0);
	}

	svg {
		width: 24px;
		height: 24px;
	}

	/* Light mode adjustments */
	:global(html.light) .back-to-top {
		background-color: var(--color-primary);
		color: var(--color-on-primary);
		box-shadow: 0 4px 12px rgba(0, 122, 88, 0.25);
	}

	:global(html.light) .back-to-top:hover {
		background-color: var(--color-primary-container);
		box-shadow: 0 6px 20px rgba(0, 122, 88, 0.35);
	}

	@media (max-width: 640px) {
		.back-to-top {
			bottom: 1.5rem;
			right: 1.5rem;
			width: 44px;
			height: 44px;
		}

		.back-to-top svg {
			width: 20px;
			height: 20px;
		}
	}
</style>

<script>
	const button = document.querySelector('.back-to-top');
	const threshold = 300;

	function updateButtonVisibility() {
		if (window.scrollY > threshold) {
			button?.classList.add('visible');
		} else {
			button?.classList.remove('visible');
		}
	}

	function scrollToTop() {
		window.scrollTo({
			top: 0,
			behavior: 'smooth',
		});
	}

	button?.addEventListener('click', scrollToTop);
	window.addEventListener('scroll', updateButtonVisibility, { passive: true });
	updateButtonVisibility();
</script>
