---
---

<section class="mobile-app" id="app" aria-labelledby="app-heading">
  <div class="section-inner">
    <div class="app-text reveal">
      <h2 id="app-heading">Carry them with you</h2>
      <p>
        Grief doesn't keep office hours. The LastRite app lets you revisit memories, receive anniversary reminders, and stay close — wherever you are.
      </p>
      <div class="platform-btns">
        <a
          href="/"
          class="btn btn-outline platform-btn"
          aria-label="Open Web Portal"
          data-coming-soon="true"
          data-feature="Web Access"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="18"
            height="18"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
            <line x1="2" y1="12" x2="22" y2="12"></line>
          </svg>
          Web Portal
        </a>
        <a
          href="/"
          class="btn btn-outline platform-btn"
          aria-label="Download on App Store"
          data-coming-soon="true"
          data-feature="iOS App Access"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="18"
            height="18"
          >
            <path
              d="M17.05 13.5c-.02-2.57 2.08-3.82 2.16-3.87-.94-1.37-2.4-1.56-2.92-1.58-1.25-.13-2.45.73-3.09.73-.65 0-1.66-.71-2.73-.69-1.41.02-2.71.82-3.44 2.09-1.47 2.56-.38 6.31 1.05 8.38.7 1.01 1.54 2.15 2.64 2.11 1.04-.04 1.43-.68 2.69-.68 1.25 0 1.62.68 2.7.66 1.12-.02 1.82-1.03 2.51-2.05.79-1.15 1.12-2.27 1.14-2.33-.02-.01-2.18-.84-2.2-3.33z"
            />
            <path
              d="M12.03 5.45c.58-.7.98-1.67.87-2.64-.84.03-1.85.56-2.44 1.27-.54.62-.99 1.6-.87 2.54.94.08 1.9-.48 2.44-1.17z"
            />
          </svg>
          App Store
        </a>
        <a
          href="/"
          class="btn btn-outline platform-btn"
          aria-label="Get it on Google Play"
          data-coming-soon="true"
          data-feature="Android App Access"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="18"
            height="18"
          >
            <path
              d="M3 12l9.5 9.5 9.5-9.5M3 12h18M12 3v18"
              stroke="currentColor"
              stroke-width="2"
              fill="none"
            />
            <path
              d="M12 4.5L5.5 12l6.5 7.5 6.5-7.5z"
              fill="currentColor"
            />
          </svg>
          Play Store
        </a>
      </div>
    </div>

    <div class="phone-mockup reveal" data-delay="2" aria-hidden="true">
      <div class="phone-card glass-panel">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <div class="phone-memorial-preview">
            <div class="preview-header"></div>
            <div class="preview-content">
              <div class="preview-line"></div>
              <div class="preview-line"></div>
              <div class="preview-line short"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .mobile-app {
    padding: 6rem 2rem;
    background: var(--color-surface);
  }

  .section-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .app-text h2 {
    margin-bottom: 1rem;
  }

  .app-text p {
    color: var(--color-on-surface-variant);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .platform-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .platform-btn {
    gap: 0.5rem;
    display: inline-flex;
  }

  .phone-card {
    aspect-ratio: 9 / 19;
    max-width: 280px;
    margin: 0 auto;
    border-radius: 36px;
    border: 8px solid var(--color-surface-container-highest);
    overflow: hidden;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .phone-notch {
    width: 40%;
    height: 22px;
    background: var(--color-surface-container-highest);
    border-radius: 0 0 10px 10px;
    margin: 0 auto;
  }

  .phone-screen {
    flex: 1;
    background: var(--color-surface-container);
    border-radius: 8px;
    overflow: hidden;
  }

  .phone-memorial-preview {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .preview-header {
    width: 100%;
    height: 40px;
    background: linear-gradient(
      135deg,
      var(--color-primary-container),
      var(--color-primary)
    );
    border-radius: 8px;
  }

  .preview-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .preview-line {
    height: 8px;
    background: var(--color-outline-variant);
    border-radius: 4px;
  }

  .preview-line.short {
    width: 60%;
  }

  @media (max-width: 720px) {
    .mobile-app {
      padding: 4rem 1.25rem;
    }

    .section-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .phone-card {
      max-width: 240px;
    }
  }
</style>
