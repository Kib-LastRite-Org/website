---
import heroSvgUrl from '@/assets/illustrations/hero-moments.svg?url';
---

<section class="hero" id="hero" aria-label="Hero section">
  <div class="hero-inner">
    <!-- Left column: Text content -->
    <div class="hero-text">
      <p class="hero-eyebrow reveal" data-delay="1">
        A space for what matters most
      </p>
      <h1 class="hero-headline reveal" data-delay="2">
        A place to <br />
        <em class="accent">remember</em>, honor, and hold on.
      </h1>
      <p class="hero-sub reveal" data-delay="3">
        When words are hard, give memories a place to live. Bring family together around a life that deserves to be remembered.
      </p>
      <div class="hero-ctas reveal flex gap-4 flex-wrap" data-delay="4">
        <a href="#cta" class="btn btn-primary">Join the Waitlist →</a>
        <a href="#how-it-works" class="btn btn-outline">See how it works</a>
      </div>
    </div>

    <!-- Right column: Visual card with badge -->
    <div class="hero-visual reveal" data-delay="2">
      <div class="hero-card glass-panel">
        <img
          src={heroSvgUrl}
          alt="Cherished moments shared by families"
          loading="eager"
          decoding="async"
          width="560"
          height="571"
          class="hero-illustration"
        />
        <div class="hero-badge flex flex-col gap-1" aria-label="Global community statistics">
          <span class="badge-label">FAMILIES WORLDWIDE</span>
          <span class="badge-stat">
            <span data-counter="4.8" data-counter-suffix="M">4.8M</span>
            Memories
          </span>
          <span class="badge-detail">Shared across 120 countries</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    background-color: var(--color-background);
    position: relative;
    overflow: hidden;
    padding: 4rem 0;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 60% at 60% 40%,
      rgba(105, 219, 173, 0.07) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    font-family: var(--font-display);
    margin-bottom: 1.5rem;
  }

  .accent {
    font-style: italic;
    color: var(--color-primary);
  }

  .hero-eyebrow {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-card {
    border-radius: var(--border-radius-card);
    overflow: hidden;
    border: 1px solid var(--color-outline-variant);
    position: relative;
  }

  .hero-illustration {
    width: 100%;
    height: auto;
    max-width: 560px;
    display: block;
    border-radius: var(--border-radius-card);
  }

  .hero-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    background: var(--color-surface-container-highest);
    border: 1px solid var(--color-outline-variant);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    animation: float 4s ease-in-out infinite;
  }

  .badge-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-on-surface-variant);
    font-weight: 600;
  }

  .badge-stat {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-display);
  }

  .badge-detail {
    font-size: 0.75rem;
    color: var(--color-on-surface-variant);
    line-height: 1.3;
  }

  @media (max-width: 720px) {
    .hero {
      min-height: auto;
      padding: 3rem 0;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 1.25rem;
    }

    .hero-visual {
      order: -1;
    }

    .hero-headline {
      font-size: clamp(1.8rem, 4vw, 2.5rem);
    }

    .hero-card {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-badge {
      animation: none;
    }
  }
</style>
