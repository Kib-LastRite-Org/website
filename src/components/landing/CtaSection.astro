<section class="cta-band" id="cta" aria-labelledby="cta-heading">
  <div class="cta-inner reveal">
    <h2 id="cta-heading">Be ready when it matters most.</h2>
    <p>Don't wait until you need it. Join early access and help us build something meaningful.</p>
    <div class="cta-buttons">
      <a href="/waitlist" class="btn btn-dark btn-lg">Join the Waitlist</a>
      <a href="/" data-coming-soon="true" data-feature="Create Memorial" class="btn btn-outline btn-lg">Create Memorial Now</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    padding: 5rem 2rem;
    background: linear-gradient(
      135deg,
      var(--color-secondary-container) 0%,
      var(--color-secondary) 60%,
      var(--color-on-secondary) 100%
    );
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-inner h2 {
    color: var(--color-on-secondary);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--color-on-secondary);
    opacity: 0.9;
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .cta-band {
      padding: 3rem 1.25rem;
    }

    .cta-inner h2 {
      font-size: clamp(1.5rem, 3vw, 2rem);
    }

    .cta-inner p {
      font-size: 0.95rem;
    }
  }
</style>
