---
---

<section
  class="how-it-works"
  id="how-it-works"
  aria-labelledby="hiw-heading"
>
  <div class="section-inner">
    <div class="section-header reveal">
      <h2 id="hiw-heading">The Journey of Remembrance</h2>
      <p class="section-sub">Three simple steps to a lasting tribute.</p>
    </div>

    <div class="steps-row" role="list">
      <div class="step reveal" data-delay="1" role="listitem">
        <div class="step-number" aria-hidden="true">01</div>
        <h3>Create</h3>
        <p>
          Build a memorial page with photos, biography, and personal stories.
        </p>
      </div>

      <div class="step-connector" aria-hidden="true"></div>

      <div class="step reveal" data-delay="2" role="listitem">
        <div class="step-number" aria-hidden="true">02</div>
        <h3>Share</h3>
        <p>
          Invite family and friends to contribute memories and condolences.
        </p>
      </div>

      <div class="step-connector" aria-hidden="true"></div>

      <div class="step reveal" data-delay="3" role="listitem">
        <div class="step-number" aria-hidden="true">03</div>
        <h3>Remember</h3>
        <p>
          Preserve the legacy forever with a living memorial that grows over
          time.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    padding: 6rem 2rem;
    background: var(--color-background);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--color-on-surface-variant);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-top: 3rem;
    list-style: none;
  }

  .step {
    flex: 1;
    text-align: center;
    padding: 0 1.5rem;
  }

  .step-number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-primary-container);
    color: var(--color-primary);
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    border: 2px solid var(--color-primary);
  }

  .step h3 {
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .step p {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .step-connector {
    flex: 1;
    height: 2px;
    background: var(--color-outline-variant);
    position: relative;
    overflow: hidden;
    align-self: center;
    margin: 0 0.5rem;
  }

  .step-connector::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-primary);
    width: 0;
    transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .step-connector.drawn::after {
    width: 100%;
  }

  @media (max-width: 720px) {
    .how-it-works {
      padding: 4rem 1.25rem;
    }

    .steps-row {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .step {
      padding: 0;
    }

    .step-connector {
      width: 2px;
      height: 40px;
      flex: none;
      margin: 0;
    }

    .step-connector::after {
      transition: height 0.7s cubic-bezier(0.4, 0, 0.2, 1);
      width: 100%;
      height: 0;
    }

    .step-connector.drawn::after {
      width: 100%;
      height: 100%;
    }
  }
</style>
