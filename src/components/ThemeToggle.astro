---

<div class="theme-toggle-wrapper">
  <button class="theme-toggle" aria-label="Toggle theme">
    <span class="toggle-knob"></span>
    <span class="icon-slot left">
      <svg class="icon sun-icon" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
        <path fill="none" stroke="currentColor" stroke-width="2"
          d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6m-16.78 7.78l4.24-4.24m5.08-5.08l4.24-4.24"/>
      </svg>
    </span>
    <span class="icon-slot right">
      <svg class="icon moon-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </span>
  </button>
</div>

<style>
  .theme-toggle-wrapper {
    display: flex;
    align-items: center;
  }

  .theme-toggle {
    position: relative;
    background: var(--surface);
    border: 2px solid var(--border, #e0e0e0);
    border-radius: 50px;
    width: 56px;
    height: 30px;
    cursor: pointer;
    display: flex;
    align-items: center;
    padding: 0;
    transition: border-color 0.3s ease;
    overflow: hidden;
  }

  .theme-toggle:hover {
    border-color: var(--accent, #7c3aed);
  }

  /* Each icon lives in its own half of the pill */
  .icon-slot {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    pointer-events: none;
  }

  .icon-slot.left  { left: 0; }
  .icon-slot.right { right: 0; }

  .icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: color 0.3s ease;
  }

  /* Knob */
  .toggle-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 22px;
    height: 22px;
    background: var(--accent, #7c3aed);
    border-radius: 50%;
    transition: transform 0.3s ease;
    z-index: 1;
  }

  /* Light mode: knob slides right */
  :global(.light) .theme-toggle .toggle-knob {
    transform: translateX(26px);
  }

  /* Icon colors — dark mode (knob on left = sun side active) */
  :global(body:not(.light)) .sun-icon { color: #fff; }
  :global(body:not(.light)) .moon-icon { color: var(--accent, #7c3aed); }

  /* Icon colors — light mode (knob on right = moon side active) */
  :global(.light) .sun-icon  { color: var(--accent, #7c3aed); }
  :global(.light) .moon-icon { color: #fff; }
</style>

<script>
  import { toggleTheme } from '../scripts/theme.js';
  const button = document.querySelector('.theme-toggle');
  if (button) button.addEventListener('click', toggleTheme);
</script>
