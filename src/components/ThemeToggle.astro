---

<div class="theme-toggle-wrapper">
	<button class="theme-toggle" aria-label="Toggle theme">
		<svg class="icon sun-icon" viewBox="0 0 24 24" aria-hidden="true">
			<circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="2"></circle>
			<path
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6m-16.78 7.78l4.24-4.24m5.08-5.08l4.24-4.24"
			></path>
		</svg>
		<svg class="icon moon-icon" viewBox="0 0 24 24" aria-hidden="true">
			<path fill="currentColor" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
		</svg>
		<span class="toggle-bg"></span>
	</button>
</div>

<style>
	.theme-toggle-wrapper {
		display: flex;
		align-items: center;
	}

	.theme-toggle {
		position: relative;
		background: var(--surface, #f5f5f5);
		border: 2px solid var(--border, #e0e0e0);
		border-radius: 50px;
		width: 56px;
		height: 32px;
		padding: 4px;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0;
		transition: border-color 0.3s ease;
	}

	.theme-toggle:hover {
		border-color: var(--accent, #7c3aed);
	}

	.icon {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		position: relative;
		z-index: 2;
		color: var(--black);
		transition: color 0.3s ease;
	}

	.sun-icon {
		margin-left: 6px;
	}

	.moon-icon {
		margin-right: 6px;
	}

	.toggle-bg {
		position: absolute;
		left: 4px;
		top: 4px;
		width: 24px;
		height: 24px;
		background: var(--accent, #7c3aed);
		border-radius: 50%;
		transition: left 0.3s ease;
		z-index: 1;
	}

	:global(.light) .theme-toggle .toggle-bg {
		left: 28px;
	}

	:global(.light) .theme-toggle .sun-icon {
		color: var(--accent, #7c3aed);
	}

	:global(.light) .theme-toggle .moon-icon {
		color: var(--black);
	}

	:global(body:not(.light)) .theme-toggle .sun-icon {
		color: var(--black);
	}

	:global(body:not(.light)) .theme-toggle .moon-icon {
		color: var(--accent, #7c3aed);
	}
</style>

<script>
	import { toggleTheme } from '../scripts/theme.js';

	const button = document.querySelector('.theme-toggle');
	if (button) {
		button.addEventListener('click', toggleTheme);
	}
</script>
