---
---

<section id="download" class="py-28 px-4 bg-dark">
  <div class="max-w-4xl mx-auto text-center">

    <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
      Get Started <span class="text-mint">Today</span>
    </h2>
    <p class="text-lg text-gray-400 mb-12">
      Available on web and Android. Free to use.
    </p>

    <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">

      <!-- Web App -->
      <a
        href="#"
        data-coming-soon
        class="group flex flex-col items-center bg-mint/8 border border-mint/25 rounded-card p-8 hover:bg-mint/14 hover:border-mint/50 hover:-translate-y-1 hover:shadow-xl hover:shadow-mint/10 transition-all duration-300 cursor-pointer"
      >
        <div class="w-14 h-14 rounded-2xl bg-mint/15 flex items-center justify-center mb-4 group-hover:bg-mint/25 transition-colors">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3EB489" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-mint mb-2">Web App</h3>
        <p class="text-gray-400 text-sm mb-5">Access from any browser, anytime, anywhere.</p>
        <span class="text-sm font-semibold text-mint">Open Web App →</span>
      </a>

      <!-- Android App -->
      <a
        href="#"
        data-coming-soon
        class="group flex flex-col items-center bg-orange/8 border border-orange/25 rounded-card p-8 hover:bg-orange/14 hover:border-orange/50 hover:-translate-y-1 hover:shadow-xl hover:shadow-orange/10 transition-all duration-300 cursor-pointer"
      >
        <div class="w-14 h-14 rounded-2xl bg-orange/15 flex items-center justify-center mb-4 group-hover:bg-orange/25 transition-colors">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF6F00" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18" stroke-width="2.5"/>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-orange mb-2">Android App</h3>
        <p class="text-gray-400 text-sm mb-5">Download from Google Play Store.</p>
        <span class="text-sm font-semibold text-orange">Download on Play Store →</span>
      </a>

    </div>

    <p class="text-gray-600 text-xs mt-8 tracking-wide">
      Free to use &nbsp;·&nbsp; No credit card required
    </p>

  </div>
</section>
