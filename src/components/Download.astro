---
---

<section id="download" class="py-28 px-4 bg-[color:var(--color-background)]">
  <div class="max-w-3xl mx-auto">
    <div class="glass-panel rounded-xl p-12 text-center">
      <span class="material-symbols-outlined icon-lg text-[color:var(--color-primary)] block mb-6">download</span>

      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-[color:var(--color-on-surface)]">
        Get Started <span class="text-[color:var(--color-primary)]">Today</span>
      </h2>
      <p class="text-lg text-[color:var(--color-on-surface-variant)] mb-12">
        Available on web and Android. Free to use.
      </p>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Web App -->
        <a
          href="#"
          data-coming-soon
          class="group flex flex-col items-center bg-[color:var(--color-surface-container-high)] rounded-card p-8 hover:scale-[1.02] transition-transform duration-300 cursor-pointer"
        >
          <div class="w-14 h-14 rounded-2xl bg-[color:var(--color-primary)]/10 flex items-center justify-center mb-4 group-hover:bg-[color:var(--color-primary)]/20 transition-colors">
            <span class="material-symbols-outlined icon-lg text-[color:var(--color-primary)]">language</span>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-primary)] mb-2">Web App</h3>
          <p class="text-[color:var(--color-on-surface-variant)] text-sm mb-5">Access from any browser, anytime, anywhere.</p>
          <span class="text-sm font-semibold text-[color:var(--color-primary)]">Open Web App →</span>
        </a>

        <!-- Android App -->
        <a
          href="#"
          data-coming-soon
          class="group flex flex-col items-center bg-[color:var(--color-surface-container-high)] rounded-card p-8 hover:scale-[1.02] transition-transform duration-300 cursor-pointer"
        >
          <div class="w-14 h-14 rounded-2xl bg-[color:var(--color-secondary)]/10 flex items-center justify-center mb-4 group-hover:bg-[color:var(--color-secondary)]/20 transition-colors">
            <span class="material-symbols-outlined icon-lg text-[color:var(--color-secondary)]">android</span>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-secondary)] mb-2">Android App</h3>
          <p class="text-[color:var(--color-on-surface-variant)] text-sm mb-5">Download from Google Play Store.</p>
          <span class="text-sm font-semibold text-[color:var(--color-secondary)]">Download on Play Store →</span>
        </a>

      </div>

      <p class="text-[color:var(--color-on-surface-variant)] text-xs mt-8 tracking-wide">
        Free to use &nbsp;·&nbsp; No credit card required
      </p>
    </div>
  </div>
</section>
