---
const isDev = import.meta.env.DEV;
---

<footer class="landing-footer">
  <div class="footer-inner">
    <!-- Col 1: Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">LastRite</a>
      <p class="footer-copyright">
        © 2026 LastRite Digital Services. All rights reserved.
      </p>
    </div>

    <!-- Col 2: Navigation -->
    <nav aria-label="Footer navigation">
      <h4>Navigation</h4>
      <ul>
        <li><a href="#features">Features</a></li>
        <li><a href="#how-it-works">How It Works</a></li>
        <li><a href="#testimonials">Testimonials</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </nav>

    <!-- Col 3: Legal -->
    <nav aria-label="Legal links">
      <h4>Legal</h4>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Service</a></li>
        <li><a href="/cookies">Cookie Policy</a></li>
      </ul>
    </nav>

    <!-- Col 4: Contact -->
    <div class="footer-contact">
      <h4>Contact</h4>
      <a href="mailto:hello@lastrite.app" class="footer-email">
        hello@lastrite.app
      </a>
      <div class="social-row">
        <a
          href="#"
          aria-label="Visit us on Twitter"
          title="Twitter"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="20"
            height="20"
          >
            <path
              d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 9 0 9-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"
            ></path>
          </svg>
        </a>
        <a
          href="#"
          aria-label="Visit us on Instagram"
          title="Instagram"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            width="20"
            height="20"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
            <circle cx="17.5" cy="6.5" r="1.5"></circle>
          </svg>
        </a>
        <a
          href="#"
          aria-label="Visit us on LinkedIn"
          title="LinkedIn"
        >
          <svg
            viewBox="0 0 24 24"
            fill="currentColor"
            width="20"
            height="20"
          >
            <path
              d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"
            ></path>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
      {isDev && (
        <div class="debug-row">
          <a
            href="/starter-home"
            class="debug-link"
            aria-label="Debug: Starter Home"
            title="Debug: Starter Home"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="20"
              height="20"
            >
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
            <span>Debug</span>
          </a>
        </div>
      )}
    </div>
  </div>
</footer>

<style>
  .landing-footer {
    background: var(--color-surface-container-lowest);
    padding: 4rem 2rem 2rem;
    border-top: 1px solid var(--color-outline-variant);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    text-decoration: none;
    display: block;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s ease;
  }

  .footer-logo:hover {
    opacity: 0.8;
  }

  .footer-copyright {
    font-size: 0.85rem;
    color: var(--color-on-surface-variant);
    line-height: 1.6;
  }

  .footer-inner nav,
  .footer-contact {
    display: flex;
    flex-direction: column;
  }

  .footer-inner h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-on-surface-variant);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .footer-inner ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-inner a {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  .footer-inner a:hover {
    color: var(--color-primary);
  }

  .footer-email {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    display: block;
  }

  .social-row {
    display: flex;
    gap: 1rem;
  }

  .social-row a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: var(--color-surface-container);
    color: var(--color-on-surface-variant);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .social-row a:hover {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }

  @media (max-width: 720px) {
    .landing-footer {
      padding: 2.5rem 1.25rem;
    }

    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-inner h4 {
      font-size: 0.8rem;
    }

    .footer-inner a {
      font-size: 0.9rem;
    }

    .footer-logo {
      font-size: 1.25rem;
    }
  }

  .debug-row {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .debug-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-outline-variant);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  .debug-link:hover {
    color: var(--color-on-surface-variant);
  }
</style>
