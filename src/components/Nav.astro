---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="fixed inset-x-0 top-0 z-50 h-16 px-6 flex items-center border-b border-outline-variant bg-surface/80 backdrop-blur-md">
  <div class="max-w-6xl mx-auto w-full flex items-center justify-between h-full">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-(--color-primary) font-bold text-xl tracking-tight hover:text-mint-light transition-colors">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2C12 2 7 7 7 13a5 5 0 0 0 10 0C17 7 12 2 12 2Z" fill="currentColor" opacity="0.95"/>
        <rect x="11" y="17" width="2" height="5" rx="1" fill="currentColor" opacity="0.4"/>
      </svg>
      LastRite
    </a>

    <!-- Nav links (hidden on mobile) -->
    <nav class="hidden sm:flex items-center gap-8 text-sm text-on-surface-variant">
      <a href="#features" class="hover:text-(--color-primary) transition-colors duration-200">Features</a>
      <a href="#howitworks" class="hover:text-(--color-primary) transition-colors duration-200">How It Works</a>
    </nav>

    <!-- Theme Toggle and CTA -->
    <div class="flex items-center gap-6">
      <ThemeToggle />
      <a
        href="#download"
        class="px-5 py-2 rounded-[10px] border border-(--color-secondary) text-(--color-secondary) text-sm font-semibold hover:bg-(--color-secondary) hover:text-on-secondary transition-all duration-200 active:scale-95"
      >
        Get Started
      </a>
    </div>

  </div>
</header>
