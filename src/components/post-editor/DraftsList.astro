---
// Sidebar collapsible list of all IndexedDB drafts.
// Fires pe:load-draft event when a draft is selected.
---
<div id="pe-drafts-section">
  <button class="pe-drafts-toggle" id="pe-drafts-toggle" aria-expanded="false">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
    </svg>
    <span id="pe-drafts-label">Drafts</span>
  </button>
  <div class="pe-drafts-list" id="pe-drafts-list" role="list">
    <div class="pe-audit__empty" id="pe-drafts-empty">No drafts yet</div>
  </div>
</div>

<script>
  import { listDrafts } from '../../utils/postStorage';

  const toggle   = document.getElementById('pe-drafts-toggle')!;
  const list     = document.getElementById('pe-drafts-list')!;
  const label    = document.getElementById('pe-drafts-label')!;
  const emptyMsg = document.getElementById('pe-drafts-empty')!;

  toggle.addEventListener('click', () => {
    const open = list.classList.toggle('pe-drafts-list--open');
    toggle.setAttribute('aria-expanded', String(open));
    if (open) renderDrafts();
  });

  async function renderDrafts() {
    const drafts = await listDrafts();
    label.textContent = `Drafts (${drafts.length})`;

    [...list.querySelectorAll('.pe-draft-item')].forEach(el => el.remove());

    if (!drafts.length) {
      emptyMsg.style.display = '';
      return;
    }

    emptyMsg.style.display = 'none';
    drafts.forEach(draft => {
      const item = document.createElement('div');
      item.className = 'pe-draft-item';
      item.setAttribute('role', 'listitem');

      const ago = formatRelative(draft.updatedAt);
      item.innerHTML = `
        <div class="pe-draft-item__title">${escapeHtml(draft.title || 'Untitled')}</div>
        <div class="pe-draft-item__meta">${escapeHtml(draft.status)} · ${ago}</div>
      `;

      item.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('pe:load-draft', { detail: draft }));
        list.classList.remove('pe-drafts-list--open');
        toggle.setAttribute('aria-expanded', 'false');
      });

      list.appendChild(item);
    });
  }

  function formatRelative(ts: number): string {
    const diff = Date.now() - ts;
    const mins = Math.floor(diff / 60_000);
    if (mins < 1)  return 'just now';
    if (mins < 60) return `${mins}m ago`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24)  return `${hrs}h ago`;
    return `${Math.floor(hrs / 24)}d ago`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  document.addEventListener('pe:draft-saved',    () => { if (list.classList.contains('pe-drafts-list--open')) renderDrafts(); });
  document.addEventListener('pe:draft-deleted',  () => renderDrafts());
  document.addEventListener('pe:auth-success',   () => renderDrafts());
</script>
