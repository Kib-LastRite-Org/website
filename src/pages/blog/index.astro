    }

    .blog-cta-input::placeholder {
      color: var(--color-outline);
    }

    .blog-cta-button {
      background-color: var(--color-primary);
      color: var(--color-on-primary);
      border: none;
      border-radius: 12px;
      padding: 0.75rem 2rem;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
