---
import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const title = 'LastRite Chronicle - Blog & Stories';
const description = 'Insights into our journey, product updates, and the stories behind digital memorials.';

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((post: any) => 'date' in post.data && post.data.date)
  .sort((a: any, b: any) => new Date(b.data.date as string).getTime() - new Date(a.data.date as string).getTime())
  .slice(0, 6);

const featuredPost = allPosts.find(p => p.data.featured) || posts[0];
const regularPosts = posts.filter(p => !p.data.featured).slice(0, 6);

const getCategoryColor = (category: string): string => {
  const colors: Record<string, string> = {
    'Engineering': 'var(--color-secondary)',
    'Stories': 'var(--color-primary)',
    'Product Updates': 'var(--color-primary)',
    'Milestones': 'var(--color-primary)',
    'Feature': 'var(--color-primary)',
  };
  return colors[category] || 'var(--color-primary)';
};

const formatDate = (dateInput: string | Date, format: 'short' | 'long' = 'short'): string => {
  const date = dateInput instanceof Date ? dateInput : new Date(dateInput);
  if (format === 'short') {
    return new Intl.DateTimeFormat('en-US', {
      month: 'short',
      day: 'numeric',
    }).format(date);
  }
  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(date);
};

const categories = ['All', 'Milestones', 'Product Updates', 'Engineering', 'Stories'];
const postDelays = ['0.1s', '0.2s', '0.3s', '0.4s', '0.5s', '0.6s'];
---

<MarketingLayout title={title} description={description}>
  <main class="blog-main">
    <!-- Hero Section -->
    <header class="blog-hero reveal">
      <h1 class="blog-hero-title">
        The LastRite Chronicle: Honoring Legacies, Building the Future.
      </h1>
      <p class="blog-hero-subtitle">
        Insights into our journey, product updates, and the stories behind digital memorials.
      </p>
    </header>

    <!-- Search & Filter Bar -->
    <section class="blog-search-filters reveal">
      <div class="blog-search-wrapper">
        <span class="material-symbols-outlined blog-search-icon">search</span>
        <input
          class="blog-search-input"
          placeholder="Search posts..."
          type="text"
        />
      </div>
      <div class="blog-filter-tabs">
        {categories.map((cat) => (
          <button
            class={`blog-filter-btn ${cat === 'All' ? 'blog-filter-btn--active' : ''}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- Featured Post -->
    <section class="blog-featured reveal">
      <a href={`/blog/${featuredPost.id}/`} class="blog-featured-link">
        <div class="blog-featured-inner">
          <img
            alt={featuredPost.data.imageAlt}
            class="blog-featured-image"
            src={featuredPost.data.image}
            loading="lazy"
          />
          <div class="blog-featured-overlay"></div>
          <div class="blog-featured-content">
            <span class="blog-featured-category">{featuredPost.data.category}</span>
            <h2 class="blog-featured-title">{featuredPost.data.title}</h2>
            <div class="blog-featured-meta">
              <span class="blog-featured-author">{featuredPost.data.author}</span>
              <span>•</span>
              <span>{formatDate(featuredPost.data.date, 'long')}</span>
              <span>•</span>
              <span>{featuredPost.data.readTime}</span>
            </div>
          </div>
        </div>
      </a>
    </section>

    <!-- Blog Grid -->
    <section class="blog-grid">
      {regularPosts.map((post, index) => (
        <a href={`/blog/${post.id}/`} class="blog-card-link">
          <article
            class="blog-card glass-panel reveal"
            style={`--reveal-delay: ${postDelays[index] || '0.6s'};`}
          >
            <div class="blog-card-image">
              <img
                alt={post.data.imageAlt}
                src={post.data.image}
                loading="lazy"
              />
            </div>
            <div class="blog-card-content">
              <span class="blog-card-category" style={`color: ${getCategoryColor(post.data.category)}`}>{post.data.category}</span>
              <h3 class="blog-card-title">
                {post.data.title}
              </h3>
              <p class="blog-card-excerpt">{post.data.excerpt}</p>
              <div class="blog-card-footer">
                <span>{post.data.author}</span>
                <span>{formatDate(post.data.date)} • {post.data.readTime}</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </section>

    <!-- Pagination -->
    <nav class="blog-pagination reveal" style="--reveal-delay: 0.7s;">
      <button class="blog-pagination-btn blog-pagination-btn--active glass-panel">1</button>
      <button class="blog-pagination-btn">2</button>
      <button class="blog-pagination-btn">3</button>
      <span class="blog-pagination-dots">...</span>
      <button class="blog-pagination-btn blog-pagination-btn--next">
        Next <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </nav>

    <!-- CTA Section -->
    <section class="blog-cta glass-panel reveal" style="--reveal-delay: 0.8s;">
      <div class="blog-cta-content">
        <h2 class="blog-cta-title">Stay updated on the future of remembrance.</h2>
        <p class="blog-cta-subtitle">
          Join 10,000+ others receiving our monthly digest on technology, grief, and legacy.
        </p>
        <form class="blog-cta-form">
          <input
            class="blog-cta-input"
            placeholder="Enter your email"
            type="email"
          />
          <button
            class="blog-cta-button"
            type="submit"
          >Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <style>
    /* Main layout */
    .blog-main {
      width: 100%;
      padding: 4rem 1.5rem 5rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    @media (max-width: 720px) {
      .blog-main {
        width: 100%;
        padding: 3rem 1rem 3rem;
      }
    }

    @media (max-width: 480px) {
      .blog-main {
        width: 100%;
        padding: 2rem 0.75rem 2.5rem;
      }
    }

    /* Hero section */
    .blog-hero {
      margin-bottom: 5rem;
    }

    .blog-hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--color-on-background);
      margin-bottom: 1.5rem;
      max-width: 800px;
    }

    .blog-hero-subtitle {
      font-size: 1.1rem;
      color: var(--color-on-surface-variant);
      line-height: 1.6;
      max-width: 600px;
    }

    @media (max-width: 720px) {
      .blog-hero {
        margin-bottom: 3rem;
      }

      .blog-hero-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        margin-bottom: 1rem;
      }

      .blog-hero-subtitle {
        font-size: 1rem;
      }
    }

    /* Search & Filter section */
    .blog-search-filters {
      display: flex;
      gap: 2rem;
      align-items: flex-start;
      margin-bottom: 4rem;
      flex-wrap: wrap;
      max-width: 100%;
    }

    .blog-search-wrapper {
      position: relative;
      flex: 0 1 100%;
      max-width: 400px;
    }

    @media (min-width: 1024px) {
      .blog-search-filters {
        flex-wrap: nowrap;
        align-items: center;
        gap: 2.5rem;
      }

      .blog-search-wrapper {
        flex: 0 0 auto;
      }

      .blog-filter-tabs {
        flex: 0 1 auto;
        gap: 1rem;
      }
    }

    .blog-search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-outline);
      font-size: 1.25rem;
    }

    .blog-search-input {
      width: 100%;
      background-color: var(--color-surface-container);
      border: 1px solid var(--color-outline-variant);
      border-radius: 12px;
      padding: 0.75rem 1rem 0.75rem 3rem;
      color: var(--color-on-background);
      font-size: 1rem;
      outline: none;
      transition: all 0.2s;
    }

    .blog-search-input:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 2px rgba(105, 219, 173, 0.1);
    }

    .blog-search-input::placeholder {
      color: var(--color-outline);
    }

    .blog-filter-tabs {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      flex: 0 1 auto;
    }

    .blog-filter-btn {
      padding: 0.5rem 1.25rem;
      border: none;
      border-radius: 20px;
      background-color: transparent;
      color: var(--color-on-surface-variant);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .blog-filter-btn:hover {
      color: var(--color-primary);
      background-color: rgba(105, 219, 173, 0.1);
    }

    .blog-filter-btn--active {
      background-color: var(--color-primary);
      color: var(--color-on-primary);
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .blog-search-filters {
        gap: 1rem;
        margin-bottom: 3rem;
      }

      .blog-search-wrapper {
        max-width: 100%;
      }

      .blog-filter-tabs {
        gap: 0.5rem;
        width: 100%;
      }

      .blog-filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.8rem;
      }
    }

    @media (max-width: 480px) {
      .blog-search-filters {
        gap: 0.75rem;
        margin-bottom: 2rem;
      }

      .blog-filter-btn {
        padding: 0.4rem 0.85rem;
        font-size: 0.75rem;
      }
    }

    /* Featured post */
    .blog-featured {
      margin-bottom: 6rem;
    }

    .blog-featured-link {
      display: block;
      text-decoration: none;
      border-radius: 16px;
      overflow: hidden;
      cursor: pointer;
    }

    .blog-featured-inner {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      height: clamp(280px, 60vw, 520px);
      display: flex;
      align-items: flex-end;
      padding: 2rem;
    }

    @media (min-width: 1024px) {
      .blog-featured {
        margin-bottom: 7rem;
      }

      .blog-featured-inner {
        padding: 3rem;
        height: clamp(320px, 50vw, 480px);
      }
    }

    .blog-featured-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
      transition: transform 0.7s ease;
    }

    .blog-featured-inner:hover .blog-featured-image {
      transform: scale(1.05);
    }

    .blog-featured-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(5, 23, 11, 1),
        rgba(5, 23, 11, 0.4),
        transparent
      );
      z-index: 1;
    }

    .blog-featured-content {
      position: relative;
      z-index: 2;
      max-width: 600px;
    }

    .blog-featured-category {
      display: inline-block;
      background-color: rgba(105, 219, 173, 0.2);
      color: var(--color-primary);
      padding: 0.375rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
      backdrop-filter: blur(12px);
    }

    .blog-featured-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 700;
      color: var(--color-on-background);
      line-height: 1.3;
      margin-bottom: 1rem;
    }

    .blog-featured-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--color-on-surface-variant);
    }

    .blog-featured-author {
      color: var(--color-on-surface);
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .blog-featured {
        margin-bottom: 4rem;
      }

      .blog-featured-inner {
        padding: 1.5rem;
        height: clamp(250px, 50vw, 350px);
      }

      .blog-featured-title {
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        margin-bottom: 0.75rem;
      }

      .blog-featured-meta {
        font-size: 0.75rem;
        gap: 0.75rem;
      }
    }

    @media (max-width: 480px) {
      .blog-featured {
        margin-bottom: 3rem;
      }

      .blog-featured-inner {
        padding: 1rem;
        height: clamp(200px, 45vw, 280px);
      }

      .blog-featured-title {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        margin-bottom: 0.5rem;
      }

      .blog-featured-meta {
        font-size: 0.7rem;
        gap: 0.5rem;
      }
    }

    /* Blog grid */
    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 6rem;
    }

    @media (min-width: 720px) {
      .blog-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .blog-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }
    }

    @media (max-width: 480px) {
      .blog-grid {
        gap: 1rem;
      }
    }

    /* Blog card link */
    .blog-card-link {
      text-decoration: none;
      display: block;
    }

    /* Blog card */
    .blog-card {
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(226, 237, 230, 0.1);
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      cursor: pointer;
    }

    .blog-card-link:hover .blog-card {
      transform: scale(1.02);
      box-shadow: 0 0 25px rgba(105, 219, 173, 0.15);
      border-color: rgba(105, 219, 173, 0.3);
    }

    .blog-card-image {
      height: 11rem;
      overflow: hidden;
    }

    .blog-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }

    .blog-card:hover .blog-card-image img {
      transform: scale(1.1);
    }

    .blog-card-content {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .blog-card-category {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }

    .blog-card-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--color-on-background);
      line-height: 1.3;
      margin-bottom: 0.75rem;
      transition: color 0.2s;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-card:hover .blog-card-title {
      color: var(--color-primary);
    }

    .blog-card-excerpt {
      font-size: 0.9rem;
      color: var(--color-on-surface-variant);
      line-height: 1.5;
      margin-bottom: 1.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-card-footer {
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--color-outline);
    }

    @media (max-width: 720px) {
      .blog-card-image {
        height: 10rem;
      }

      .blog-card-content {
        padding: 1.25rem;
      }
    }

    @media (max-width: 480px) {
      .blog-card-image {
        height: 8.5rem;
      }

      .blog-card-content {
        padding: 1rem;
      }

      .blog-card-title {
        font-size: 1rem;
        margin-bottom: 0.5rem;
      }

      .blog-card-excerpt {
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }
    }

    /* Pagination */
    .blog-pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin-bottom: 6rem;
      flex-wrap: wrap;
    }

    .blog-pagination-btn {
      width: 2.5rem;
      height: 2.5rem;
      border: none;
      border-radius: 12px;
      background-color: transparent;
      color: var(--color-on-surface-variant);
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .blog-pagination-btn:hover {
      color: var(--color-primary);
      background-color: rgba(105, 219, 173, 0.1);
    }

    .blog-pagination-btn--active {
      border: 1px solid rgba(226, 237, 230, 0.1);
      color: var(--color-on-surface);
    }

    .blog-pagination-btn--next {
      width: auto;
      padding: 0.5rem 1.25rem;
    }

    .blog-pagination-dots {
      color: var(--color-outline);
      padding: 0 0.5rem;
    }

    @media (max-width: 720px) {
      .blog-pagination {
        gap: 0.5rem;
        margin-bottom: 4rem;
      }

      .blog-pagination-btn {
        width: 2rem;
        height: 2rem;
        font-size: 0.875rem;
      }
    }

    @media (max-width: 480px) {
      .blog-pagination {
        gap: 0.35rem;
        margin-bottom: 3rem;
      }

      .blog-pagination-btn {
        width: 1.75rem;
        height: 1.75rem;
        font-size: 0.75rem;
      }

      .blog-pagination-btn--next {
        padding: 0.4rem 1rem;
        font-size: 0.75rem;
      }

      .blog-pagination-dots {
        padding: 0 0.25rem;
      }
    }

    /* CTA section */
    .blog-cta {
      border-radius: 16px;
      border: 1px solid rgba(226, 237, 230, 0.1);
      padding: 4rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    @media (min-width: 1024px) {
      .blog-cta {
        padding: 5rem 4rem;
      }

      .blog-cta-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
      }

      .blog-cta-form {
        max-width: 600px;
      }
    }

    .blog-cta::before {
      content: '';
      position: absolute;
      top: -6rem;
      left: -6rem;
      width: 16rem;
      height: 16rem;
      background: radial-gradient(circle, rgba(105, 219, 173, 0.1), transparent);
      border-radius: 50%;
      z-index: 0;
    }

    .blog-cta::after {
      content: '';
      position: absolute;
      bottom: -6rem;
      right: -6rem;
      width: 16rem;
      height: 16rem;
      background: radial-gradient(circle, rgba(255, 182, 145, 0.1), transparent);
      border-radius: 50%;
      z-index: 0;
    }

    .blog-cta-content {
      position: relative;
      z-index: 1;
    }

    .blog-cta-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 700;
      color: var(--color-on-background);
      margin-bottom: 1rem;
    }

    .blog-cta-subtitle {
      font-size: 1rem;
      color: var(--color-on-surface-variant);
      margin-bottom: 2rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.6;
    }

    .blog-cta-form {
      display: flex;
      gap: 1rem;
      max-width: 500px;
      margin: 0 auto;
      flex-wrap: wrap;
      justify-content: center;
    }

    .blog-cta-input {
      flex: 1;
      min-width: 250px;
      background-color: var(--color-surface);
      border: 1px solid var(--color-outline-variant);
      border-radius: 12px;
      padding: 0.75rem 1.5rem;
      color: var(--color-on-background);
      font-size: 1rem;
      outline: none;
      transition: all 0.2s;
    }

    .blog-cta-input:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 2px rgba(105, 219, 173, 0.1);
    }

    .blog-cta-input::placeholder {
      color: var(--color-outline);
    }

    .blog-cta-button {
      background-color: var(--color-primary);
      color: var(--color-on-primary);
      border: none;
      border-radius: 12px;
      padding: 0.75rem 2rem;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .blog-cta-button:hover {
      box-shadow: 0 0 20px rgba(105, 219, 173, 0.4);
    }

    @media (max-width: 720px) {
      .blog-cta {
        padding: 2rem 1.5rem;
      }

      .blog-cta-title {
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        margin-bottom: 0.75rem;
      }

      .blog-cta-subtitle {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
      }

      .blog-cta-form {
        flex-direction: column;
      }

      .blog-cta-input {
        min-width: 100%;
        padding: 0.65rem 1rem;
        font-size: 0.95rem;
      }

      .blog-cta-button {
        width: 100%;
        padding: 0.65rem 1.5rem;
      }
    }

    @media (max-width: 480px) {
      .blog-cta {
        padding: 1.5rem 1rem;
      }

      .blog-cta-title {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        margin-bottom: 0.5rem;
      }

      .blog-cta-subtitle {
        font-size: 0.85rem;
        margin-bottom: 1.25rem;
      }

      .blog-cta-input {
        padding: 0.6rem 0.85rem;
        font-size: 0.9rem;
      }

      .blog-cta-button {
        padding: 0.6rem 1.25rem;
        font-size: 0.9rem;
      }
    }

  </style>
</MarketingLayout>
