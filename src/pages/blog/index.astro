---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const title = 'LastRite Chronicle - Blog & Stories';
const description = 'Insights into our journey, product updates, and the stories behind digital memorials.';

const posts = [
  {
    id: 1,
    category: 'Engineering',
    categoryColor: 'var(--color-secondary)',
    title: 'Scaling Memorial Services for Global Reach',
    excerpt: 'How we optimized our database for high-traffic memorial anniversaries and distributed global edge delivery.',
    author: 'Alex Chen',
    date: 'Apr 28',
    readTime: '8 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD3Huz8BFCQuBrMBVizF696hUgjeZ9yUAFRYD0v5ABltuei3Sp9g3aKDUfbjIrSrEsrZhQMAFiHI5SLpm943PQPW9n3nni8dyCIjJMcENNuRohDdJrbh8yC4JlMhAeEDQ2lqPVfuFLP7371IMtn_xcI5MtmFlOk04i9MArfJDWfhB5GpV6BBHSQFS3waRMoq26AIChnrM8o07WP-35qe6dHzm5WMcra2_kh9D3B6pApWrg5w9Zvcgfi3fTgyswmCadYgC3LpO662Zoj',
    imageAlt: 'close-up of complex circuit board with glowing emerald light pathways illuminating futuristic server architecture',
    delay: '0.1s',
  },
  {
    id: 2,
    category: 'Stories',
    categoryColor: 'var(--color-primary)',
    title: 'Finding Solace in Digital Heirlooms',
    excerpt: 'Personal accounts of how shared digital legacies helped a community heal after unexpected loss.',
    author: 'Elena Rossi',
    date: 'May 05',
    readTime: '5 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCu_hZCbr7BAU2xZGdPjsWvHn0sZQB1XXnRTG34z0vs7kOzi-XSKq5xafi4JpeMpKbSwyUq_D8mHuoWp4vB0lNKoMjbs_ORGoQE_7-2Ibg1OUGXjhlZdFhgfkVBST4y2qawEnNdS7yom211NJ9AMiRc9kPlSsY5PoD14CHmMn-ATtQN0a987XzMP-EkDd_uKrDGGQoHEtOAQsMf70AE6kfNrzrxtGGm24iso_-8EdSUpVX_PbwI-N0K2hBtultCwi8E_TehJRY5QUrc',
    imageAlt: 'soft focus of a family sitting together in a sun-drenched library sharing a tablet with warm emotional lighting',
    delay: '0.2s',
  },
  {
    id: 3,
    category: 'Product Updates',
    categoryColor: 'var(--color-primary)',
    title: 'The New LastRite Mobile Experience',
    excerpt: 'A complete overhaul of our mobile application to focus on accessibility and mindful interaction.',
    author: 'David Park',
    date: 'May 10',
    readTime: '4 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCU_DV15iPvc7JqQhyeePGNdqLuHltpLJqfa2j-RfUfjIj4rHgvbAB-szYGe9P4gCNTLoxJ5EskxOmZsxm5U8rpOLsvFhNBwFlAEGPqJTPhPjnm3G2UeUWJFkh6lXWRHNmTWb4W0HtbpawxVwLjFI7y1VZgygcuUw88AwSRsXysKlLcOYJKo67DHOmmbfalw3nt8I5sfZKmW_uk4-ZlJ_CP-L_xRwSued63jj9fyxRTTnd7oxqUDQ2wFnNNcn5rTfHQE15mR4ysxT1d',
    imageAlt: 'minimalist white desk with a glowing smartphone displaying a clean user interface with floral motifs',
    delay: '0.3s',
  },
  {
    id: 4,
    category: 'Engineering',
    categoryColor: 'var(--color-secondary)',
    title: 'Encryption Standards for Eternal Privacy',
    excerpt: 'Deep dive into our zero-knowledge architecture ensuring your memories stay private for generations.',
    author: 'Marcus Thorne',
    date: 'Apr 15',
    readTime: '12 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuAR4wFsbcuM2aZ_-zJw6DJZW0L0PL_9vLFnWZJFWmG0GT91EU3dFcTWoHWd1gmQfLFSrZFjpKJmZgmjYRu1h4aRxXlMn84U8EFCNntuH-YDE8hWqltwxi0OnMgSAOERxE-dBU3d3WNpHpYsovDJ4BYYNggbAWq2TCPVwh5oEBuUKQ-Hnqi9RzVluOCOMHLbcICVczeBInqruDJyyESm6jK2Lps3qa2MS7jndJvkkJPllEj3FwnVXQ_aQE2EoqD8AlPP91KZZmedBplL',
    imageAlt: 'macro photography of a single glowing tree leaf with golden veins against a deep dark background',
    delay: '0.4s',
  },
  {
    id: 5,
    category: 'Milestones',
    categoryColor: 'var(--color-primary)',
    title: 'Reaching 1 Million Legacies Protected',
    excerpt: 'Celebrating the global community that trusts LastRite to preserve their most precious stories.',
    author: 'Sarah Miller',
    date: 'Apr 02',
    readTime: '3 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCZoYkywkGv6s9D_wpca-tNDNkzDzOhZO7HGAYSWfu_macFZQOsYAcI2ijlqiz44i_goBvgvT-ziATPJxfgm0Fqv1l4A_WPgYs3YAzJ8JX7SmHwiDNqfONX0_9jzsHzkmPbGItGJHw0Z5BnB5zFjq2ZaulYgpa2FXxY2qC974i4V_W-dcU2WN6U9Jj_QZOcpAyxWfLZKEDA5W6ba0zZK6MmmG_NxiqLQ6ShoVwcX4Zi5wAFRjHU4dZHrI7B_3hKmMDOROtU5wzLz9xt',
    imageAlt: 'abstract composition of floating geometric crystals glowing with soft mint and orange light in a dark void',
    delay: '0.5s',
  },
  {
    id: 6,
    category: 'Stories',
    categoryColor: 'var(--color-primary)',
    title: 'The Philosophy of Digital Immortality',
    excerpt: 'A thoughtful exploration of what it means to live on through the pixels and memories we leave behind.',
    author: 'Julian Vane',
    date: 'Mar 25',
    readTime: '15 min',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBcAtfPudYl51fiNHjvCLc0M8tcG9UrmUIJd2OchrkydFvUvL-5iYLtTYkFwekmrEvVzDukY2CfFZ0WRUIwilQd01sg0jHez5yDoyBJF1YHtT0S9aNOdkuKtSf3QN6f11Ql3Dp6_Eevu5KmoCyeL5uZCVzTOgqxQGEGk_guYVjE0REHchscG5nShxoIUyI6WQnKLPISP-AxHP2TB22U1kynPkI0TFKsDz5hvT4-bk-c40dIpIDMAl6cVZZS9YpD_M3Oa86p5MF8oNcN',
    imageAlt: 'low angle shot of ancient oak trees in a misty forest with ethereal light beams filtering through the canopy',
    delay: '0.6s',
  },
];

const featuredPost = {
  title: 'Introducing Memorial Spaces: A New Way to Gather and Grieve',
  category: 'Feature',
  author: 'Sarah Miller',
  date: 'May 12, 2024',
  readTime: '6 min read',
  image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuALJBsT8UghXJYO7Qs7XdOh0F9KoriWH4prgOvEGhlQjYyLD1g2tssmWAs8tJkRMSES-wbzk6hHs5bFy3ewC-fxzqe_mU54cxyzhgvkhfxAeF1p5SAkNDZhMmK14ViuSbglQcaC_0-MJL7Hxn-mXGrdrWRPHnH3op_5XOzvmFPdttkwL0mm76EVK9nbk-DtuT6z1Uq3zR2LabxZkio3kdLBJtW_0dBSCdJJcQ8wM1gK5QUS2CUG_l9UkEdKsbh9a6zfQSrZ4ZtqURIy',
  imageAlt: 'dramatic wide shot of a serene mountain lake at twilight with glowing digital particles rising like stars into the night sky',
};

const categories = ['All', 'Milestones', 'Product Updates', 'Engineering', 'Stories'];
---

<MarketingLayout title={title} description={description}>
  <main class="blog-main">
    <!-- Hero Section -->
    <header class="blog-hero reveal">
      <h1 class="blog-hero-title">
        The LastRite Chronicle: Honoring Legacies, Building the Future.
      </h1>
      <p class="blog-hero-subtitle">
        Insights into our journey, product updates, and the stories behind digital memorials.
      </p>
    </header>

    <!-- Search & Filter Bar -->
    <section class="blog-search-filters reveal">
      <div class="blog-search-wrapper">
        <span class="material-symbols-outlined blog-search-icon">search</span>
        <input
          class="blog-search-input"
          placeholder="Search posts..."
          type="text"
        />
      </div>
      <div class="blog-filter-tabs">
        {categories.map((cat) => (
          <button
            class={`blog-filter-btn ${cat === 'All' ? 'blog-filter-btn--active' : ''}`}
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- Featured Post -->
    <section class="blog-featured reveal">
      <div class="blog-featured-inner">
        <img
          alt={featuredPost.imageAlt}
          class="blog-featured-image"
          src={featuredPost.image}
        />
        <div class="blog-featured-overlay"></div>
        <div class="blog-featured-content">
          <span class="blog-featured-category">{featuredPost.category}</span>
          <h2 class="blog-featured-title">{featuredPost.title}</h2>
          <div class="blog-featured-meta">
            <span class="blog-featured-author">{featuredPost.author}</span>
            <span>•</span>
            <span>{featuredPost.date}</span>
            <span>•</span>
            <span>{featuredPost.readTime}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog Grid -->
    <section class="blog-grid">
      {posts.map((post) => (
        <article
          class="blog-card reveal"
          style={`animation-delay: ${post.delay};`}
        >
          <div class="blog-card-image">
            <img
              alt={post.imageAlt}
              src={post.image}
            />
          </div>
          <div class="blog-card-content">
            <span class="blog-card-category" style={`color: ${post.categoryColor}`}>{post.category}</span>
            <h3 class="blog-card-title">
              {post.title}
            </h3>
            <p class="blog-card-excerpt">{post.excerpt}</p>
            <div class="blog-card-footer">
              <span>{post.author}</span>
              <span>{post.date} • {post.readTime}</span>
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Pagination -->
    <nav class="blog-pagination reveal">
      <button class="blog-pagination-btn blog-pagination-btn--active">1</button>
      <button class="blog-pagination-btn">2</button>
      <button class="blog-pagination-btn">3</button>
      <span class="blog-pagination-dots">...</span>
      <button class="blog-pagination-btn blog-pagination-btn--next">
        Next <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </nav>

    <!-- CTA Section -->
    <section class="blog-cta reveal">
      <div class="blog-cta-content">
        <h2 class="blog-cta-title">Stay updated on the future of remembrance.</h2>
        <p class="blog-cta-subtitle">
          Join 10,000+ others receiving our monthly digest on technology, grief, and legacy.
        </p>
        <form class="blog-cta-form">
          <input
            class="blog-cta-input"
            placeholder="Enter your email"
            type="email"
          />
          <button
            class="blog-cta-button"
            type="submit"
          >Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <style>
    /* Main layout */
    .blog-main {
      width: 100%;
      padding: 4rem 1.5rem 5rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    @media (max-width: 720px) {
      .blog-main {
        width: 100%;
        padding: 3rem 1rem 3rem;
      }
    }

    @media (max-width: 480px) {
      .blog-main {
        width: 100%;
        padding: 2rem 0.75rem 2.5rem;
      }
    }

    /* Hero section */
    .blog-hero {
      margin-bottom: 5rem;
    }

    .blog-hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.2;
      color: var(--color-on-background);
      margin-bottom: 1.5rem;
      max-width: 800px;
    }

    .blog-hero-subtitle {
      font-size: 1.1rem;
      color: var(--color-on-surface-variant);
      line-height: 1.6;
      max-width: 600px;
    }

    @media (max-width: 720px) {
      .blog-hero {
        margin-bottom: 3rem;
      }

      .blog-hero-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        margin-bottom: 1rem;
      }

      .blog-hero-subtitle {
        font-size: 1rem;
      }
    }

    /* Search & Filter section */
    .blog-search-filters {
      display: flex;
      gap: 2rem;
      align-items: flex-start;
      margin-bottom: 4rem;
      flex-wrap: wrap;
      max-width: 100%;
    }

    .blog-search-wrapper {
      position: relative;
      flex: 0 1 100%;
      max-width: 400px;
    }

    @media (min-width: 1024px) {
      .blog-search-filters {
        flex-wrap: nowrap;
        align-items: center;
        gap: 2.5rem;
      }

      .blog-search-wrapper {
        flex: 0 0 auto;
      }

      .blog-filter-tabs {
        flex: 0 1 auto;
        gap: 1rem;
      }
    }

    .blog-search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-outline);
      font-size: 1.25rem;
    }

    .blog-search-input {
      width: 100%;
      background-color: var(--color-surface-container);
      border: 1px solid var(--color-outline-variant);
      border-radius: 12px;
      padding: 0.75rem 1rem 0.75rem 3rem;
      color: var(--color-on-background);
      font-size: 1rem;
      outline: none;
      transition: all 0.2s;
    }

    .blog-search-input:focus {
      border-color: var(--color-primary);
      box-shadow: 0 0 0 2px rgba(105, 219, 173, 0.1);
    }

    .blog-search-input::placeholder {
      color: var(--color-outline);
    }

    .blog-filter-tabs {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      flex: 0 1 auto;
    }

    .blog-filter-btn {
      padding: 0.5rem 1.25rem;
      border: none;
      border-radius: 20px;
      background-color: transparent;
      color: var(--color-on-surface-variant);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .blog-filter-btn:hover {
      color: var(--color-primary);
      background-color: rgba(105, 219, 173, 0.1);
    }

    .blog-filter-btn--active {
      background-color: var(--color-primary);
      color: var(--color-on-primary);
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .blog-search-filters {
        gap: 1rem;
        margin-bottom: 3rem;
      }

      .blog-search-wrapper {
        max-width: 100%;
      }

      .blog-filter-tabs {
        gap: 0.5rem;
        width: 100%;
      }

      .blog-filter-btn {
        padding: 0.5rem 1rem;
        font-size: 0.8rem;
      }
    }

    @media (max-width: 480px) {
      .blog-search-filters {
        gap: 0.75rem;
        margin-bottom: 2rem;
      }

      .blog-filter-btn {
        padding: 0.4rem 0.85rem;
        font-size: 0.75rem;
      }
    }

    /* Featured post */
    .blog-featured {
      margin-bottom: 6rem;
    }

    .blog-featured-inner {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      height: clamp(280px, 60vw, 520px);
      display: flex;
      align-items: flex-end;
      padding: 2rem;
    }

    @media (min-width: 1024px) {
      .blog-featured {
        margin-bottom: 7rem;
      }

      .blog-featured-inner {
        padding: 3rem;
        height: clamp(320px, 50vw, 480px);
      }
    }

    .blog-featured-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
      transition: transform 0.7s ease;
    }

    .blog-featured-inner:hover .blog-featured-image {
      transform: scale(1.05);
    }

    .blog-featured-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(5, 23, 11, 1),
        rgba(5, 23, 11, 0.4),
        transparent
      );
      z-index: 1;
    }

    .blog-featured-content {
      position: relative;
      z-index: 2;
      max-width: 600px;
    }

    .blog-featured-category {
      display: inline-block;
      background-color: rgba(105, 219, 173, 0.2);
      color: var(--color-primary);
      padding: 0.375rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
      backdrop-filter: blur(12px);
    }

    .blog-featured-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 4vw, 2rem);
      font-weight: 700;
      color: var(--color-on-background);
      line-height: 1.3;
      margin-bottom: 1rem;
    }

    .blog-featured-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;
      color: var(--color-on-surface-variant);
    }

    .blog-featured-author {
      color: var(--color-on-surface);
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .blog-featured {
        margin-bottom: 4rem;
      }

      .blog-featured-inner {
        padding: 1.5rem;
        height: clamp(250px, 50vw, 350px);
      }

      .blog-featured-title {
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        margin-bottom: 0.75rem;
      }

      .blog-featured-meta {
        font-size: 0.75rem;
        gap: 0.75rem;
      }
    }

    @media (max-width: 480px) {
      .blog-featured {
        margin-bottom: 3rem;
      }

      .blog-featured-inner {
        padding: 1rem;
        height: clamp(200px, 45vw, 280px);
      }

      .blog-featured-title {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        margin-bottom: 0.5rem;
      }

      .blog-featured-meta {
        font-size: 0.7rem;
        gap: 0.5rem;
      }
    }

    /* Blog grid */
    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 6rem;
    }

    @media (min-width: 720px) {
      .blog-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .blog-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }
    }

    @media (max-width: 480px) {
      .blog-grid {
        gap: 1rem;
      }
    }

    /* Blog card */
    .blog-card {
      border-radius: 16px;
      overflow: hidden;
      background: rgba(13, 31, 20, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(226, 237, 230, 0.1);
      display: flex;
      flex-direction: column;
      transition: all 0.3s;
      cursor: pointer;
    }

    .blog-card:hover {
      transform: scale(1.02);
      box-shadow: 0 0 25px rgba(105, 219, 173, 0.15);
      border-color: rgba(105, 219, 173, 0.3);
    }

    .blog-card-image {
      height: 11rem;
      overflow: hidden;
    }

    .blog-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }

    .blog-card:hover .blog-card-image img {
      transform: scale(1.1);
    }

    .blog-card-content {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .blog-card-category {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.75rem;
    }

    .blog-card-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--color-on-background);
      line-height: 1.3;
      margin-bottom: 0.75rem;
      transition: color 0.2s;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-card:hover .blog-card-title {
      color: var(--color-primary);
    }

    .blog-card-excerpt {
      font-size: 0.9rem;
      color: var(--color-on-surface-variant);
      line-height: 1.5;
      margin-bottom: 1.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-card-footer {
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--color-outline);
    }

    @media (max-width: 720px) {
      .blog-card-image {
        height: 10rem;
      }

      .blog-card-content {
        padding: 1.25rem;
      }
    }

    @media (max-width: 480px) {
      .blog-card-image {
        height: 8.5rem;
      }

      .blog-card-content {
        padding: 1rem;
      }

      .blog-card-title {
        font-size: 1rem;
        margin-bottom: 0.5rem;
      }

      .blog-card-excerpt {
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }
    }

    /* Pagination */
    .blog-pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin-bottom: 6rem;
      flex-wrap: wrap;
    }

    .blog-pagination-btn {
      width: 2.5rem;
      height: 2.5rem;
      border: none;
      border-radius: 12px;
      background-color: transparent;
      color: var(--color-on-surface-variant);
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .blog-pagination-btn:hover {
      color: var(--color-primary);
      background-color: rgba(105, 219, 173, 0.1);
    }

    .blog-pagination-btn--active {
      background: rgba(13, 31, 20, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(226, 237, 230, 0.1);
      color: var(--color-on-surface);
    }

    .blog-pagination-btn--next {
      width: auto;
      padding: 0.5rem 1.25rem;
    }

    .blog-pagination-dots {
      color: var(--color-outline);
      padding: 0 0.5rem;
    }

    @media (max-width: 720px) {
      .blog-pagination {
        gap: 0.5rem;
        margin-bottom: 4rem;
      }

      .blog-pagination-btn {
        width: 2rem;
