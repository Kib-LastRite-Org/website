---
import BaseHead from '../components/BaseHead.astro';
import BackToTopButton from '../components/BackToTopButton.astro';
import LandingHeader from '../components/LandingHeader.astro';
import LandingFooter from '../components/LandingFooter.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import FeaturesSection from '../components/landing/FeaturesSection.astro';
import HowItWorksSection from '../components/landing/HowItWorksSection.astro';
import MobileAppSection from '../components/landing/MobileAppSection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';
import CtaSection from '../components/landing/CtaSection.astro';

const title = 'LastRite — Celebrate a Life Well Lived';
const description =
  'Create meaningful obituaries, share cherished memories, and organize memorial fundraising—all in one place. Join millions honoring their loved ones.';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <LandingHeader />
    <main class="landing" id="main-content">
      <HeroSection />
      <FeaturesSection />
      <HowItWorksSection />
      <MobileAppSection />
      <TestimonialsSection />
      <CtaSection />
    </main>
    <LandingFooter />
    <BackToTopButton />

    <script>
      import { initAll } from '../scripts/animations.js';
      import { initComingSoonInterceptor } from '../scripts/comingSoonInterceptor';
      import { initLastRiteToastInterceptor } from '../scripts/lastRiteToastInterceptor';

      // Call animations and coming-soon interceptor on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initAll();
          initComingSoonInterceptor();
          initLastRiteToastInterceptor();
        });
      } else {
        initAll();
        initComingSoonInterceptor();
        initLastRiteToastInterceptor();
      }
    </script>
  </body>
</html>
