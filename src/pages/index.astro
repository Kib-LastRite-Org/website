---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import FeaturesSection from '../components/landing/FeaturesSection.astro';
import HowItWorksSection from '../components/landing/HowItWorksSection.astro';
import MobileAppSection from '../components/landing/MobileAppSection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';
import CtaSection from '../components/landing/CtaSection.astro';

const title = 'LastRite — A Place to Remember, Honor, and Hold On';
const description =
  'Grief is hard enough. LastRite gives families a gentle space to share memories, honor a life, and stay together through it all.';
---

<MarketingLayout title={title} description={description}>
    <main class="landing" id="main-content">
      <HeroSection />
      <FeaturesSection />
      <HowItWorksSection />
      <MobileAppSection />
      <TestimonialsSection />
      <CtaSection />
    </main>

    <script>
      import { initAll } from '@/scripts/animations';

      // Call animations and coming-soon interceptor on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initAll();
        });
      } else {
        initAll();
      }
    </script>
</MarketingLayout>
