---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Privacy Policy - LastRite"
  description="Learn how LastRite protects your personal data and privacy"
>
  <div class="min-h-screen bg-[color:var(--color-background)]">
    <!-- Header -->
    <div class="bg-[color:var(--color-surface-container)] py-12 px-4 border-b border-[color:var(--color-outline-variant)]">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold text-[color:var(--color-primary)] mb-2">Privacy Policy</h1>
        <p class="text-[color:var(--color-on-surface-variant)]">Last updated: April 15, 2026</p>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto py-12 px-4">
      <div class="space-y-8 text-[color:var(--color-on-surface-variant)]">
        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">Introduction</h2>
          <p>
            LastRite ("we," "us," "our," or "Company") operates the LastRite website and mobile application.
            This Privacy Policy explains our data practices and your privacy rights.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">Information We Collect</h2>
          <p class="mb-4">We collect information you provide directly, including:</p>
          <ul class="list-disc list-inside space-y-2 ml-2">
            <li>Account information (name, email, phone)</li>
            <li>Profile data (obituaries, memorial content, photos)</li>
            <li>Payment information (processed securely through third parties)</li>
            <li>Communication data (support requests, feedback)</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">How We Use Your Information</h2>
          <p class="mb-4">We use collected information to:</p>
          <ul class="list-disc list-inside space-y-2 ml-2">
            <li>Provide and improve our services</li>
            <li>Send transactional emails and support notifications</li>
            <li>Comply with legal obligations</li>
            <li>Prevent fraud and secure your account</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">Data Security</h2>
          <p>
            We implement industry-standard encryption and security measures to protect your personal data.
            However, no method of transmission over the Internet is 100% secure.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">Your Rights</h2>
          <p class="mb-4">You have the right to:</p>
          <ul class="list-disc list-inside space-y-2 ml-2">
            <li>Access your personal data</li>
            <li>Request correction or deletion of your data</li>
            <li>Opt out of marketing communications</li>
            <li>Export your data</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-[color:var(--color-primary)] mb-4">Contact Us</h2>
          <p>
            If you have questions about this Privacy Policy, please contact us at{" "}
            <a href="#" data-coming-soon class="text-[color:var(--color-secondary)] hover:text-[color:var(--color-primary)] font-semibold">
              hello@lastrite.com
            </a>
          </p>
        </section>
      </div>

      <!-- Back to Home -->
      <div class="mt-12 pt-8 border-t border-[color:var(--color-outline-variant)]">
        <a
          href="/"
          class="inline-block px-6 py-2 bg-[color:var(--color-primary)] text-[color:var(--color-on-primary)] font-semibold rounded-btn hover:opacity-90 transition-opacity"
        >
          ← Back to Home
        </a>
      </div>
    </div>
  </div>
</Layout>
