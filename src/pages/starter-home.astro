---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BackToTopButton from '../components/BackToTopButton.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="home-btn-container">
				<a href="/" class="home-btn" aria-label="Back to home">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
						<polyline points="15 18 9 12 15 6"></polyline>
					</svg>
					<span>Home</span>
				</a>
			</div>
			<h1>LastRite</h1>
			<p>
				Create meaningful obituaries, share cherished memories, and organize memorial fundraising—all in one place.
			</p>
			<h2>Coming Soon</h2>
			<p>
				LastRite is currently in development. Join us to transform how families honor and remember their loved ones.
			</p>
			<p>
				Built with care using <a href="https://astro.build/">Astro</a>, a modern static site generator.
			</p>
		</main>
		<Footer />
		<BackToTopButton />
	</body>
</html>

<style>
	main {
		position: relative;
	}

	.home-btn-container {
		padding: 2rem 0 1rem 0;
	}

	.home-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 1rem;
		color: var(--color-on-surface-variant);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		border: 1px solid var(--color-outline-variant);
		border-radius: 6px;
		transition: all 0.2s ease;
	}

	.home-btn:hover {
		color: var(--color-primary);
		border-color: var(--color-primary);
		background: var(--color-surface-container);
	}

	.home-btn svg {
		transition: transform 0.2s ease;
	}

	.home-btn:hover svg {
		transform: translateX(-2px);
	}
</style>
