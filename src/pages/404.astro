---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { getCollection } from 'astro:content';
import NotFoundIllustration from '@/components/NotFoundIllustration.astro';

// Set proper HTTP status code for SSR
Astro.response.status = 404;
Astro.response.statusText = 'Not Found';

const blogPosts = await getCollection('posts');
const recentMemorials = blogPosts
  .filter((post: any) => 'date' in post.data && post.data.date)
  .sort((a: any, b: any) => new Date(b.data.date as string).getTime() - new Date(a.data.date as string).getTime())
  .slice(0, 3);
---

<MarketingLayout title="404 - Page Not Found" description="The page you're looking for has drifted away, but your memories remain.">
  <main class="not-found-container">
    <!-- Hero section with illustration -->
    <section class="hero-404" data-fade-in>
      <div class="illustration-wrapper">
        <NotFoundIllustration />
      </div>

      <h1 class="headline-404">Page Not Found</h1>

      <!-- Display the incorrect URL -->
      <div class="url-display">
        <code class="incorrect-url">{new URL(Astro.request.url).pathname}</code>
      </div>

      <p class="subheading-404">
        The page you're looking for doesn't exist. Let's get you back on track.
      </p>
    </section>

    <!-- Quick action cards - horizontal grid with descriptions -->
    <section class="action-cards-404">
      <a href="/" class="action-card">
        <div class="card-icon-wrapper">
          <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </div>
        <div class="card-content">
          <h3>Return Home</h3>
          <p>Begin again at the entrance of our collective archive.</p>
        </div>
      </a>
      <a href="/blog" class="action-card">
        <div class="card-icon-wrapper">
          <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
        </div>
        <div class="card-content">
          <h3>Browse Memorials</h3>
          <p>Explore the stories and legacies preserved within our walls.</p>
        </div>
      </a>
      <a href="/waitlist" class="action-card coming-soon" data-coming-soon>
        <div class="card-icon-wrapper">
          <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
            <polyline points="13 2 13 9 20 9"></polyline>
            <path d="M16 13H8"></path>
            <path d="M16 17H8"></path>
            <path d="M10 9H8"></path>
          </svg>
        </div>
        <div class="card-content">
          <h3>Visit Waitlist</h3>
          <p>Secure your place in the upcoming expansion of the archive.</p>
        </div>
      </a>
      <a href="/#cta" class="action-card">
        <div class="card-icon-wrapper">
          <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <div class="card-content">
          <h3>Contact Support</h3>
          <p>Speak with a curator if you believe something is missing.</p>
        </div>
      </a>
    </section>

    <!-- Recent memorials preview - horizontal scroll on mobile, grid on desktop -->
    {recentMemorials.length > 0 && (
      <section class="recent-section-404">
        <h2>Recent Memorials</h2>
        <div class="memorial-grid">
          {recentMemorials.map((post: any) => (
            <a href="/blog" class="memorial-card-compact">
              <h3>{post.data.title}</h3>
              <time class="memorial-date">{new Date(post.data.date as string).toLocaleDateString()}</time>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- System status -->
    <div class="system-status">
      <span class="status-indicator">✓</span>
      <p>All systems operational</p>
    </div>
  </main>
</MarketingLayout>

<style>
  .not-found-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    gap: 2rem;
    background: linear-gradient(
      135deg,
      var(--color-background) 0%,
      var(--color-surface-container) 100%
    );
  }

  /* Hero section */
  .hero-404 {
    text-align: center;
    max-width: 500px;
    animation: fadeInDown 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .illustration-wrapper {
    margin: 0 auto 1.5rem;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .illustration-404 {
    width: 100%;
    height: 100%;
    animation: float 4s cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
    filter: drop-shadow(0 8px 16px rgba(105, 219, 173, 0.15));
  }

  .headline-404 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-on-surface);
    margin: 0 0 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .url-display {
    margin: 1rem 0 0.75rem;
    animation: fadeIn 0.8s ease 0.2s backwards;
  }

  .incorrect-url {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: rgba(105, 219, 173, 0.08);
    border: 1px solid rgba(105, 219, 173, 0.15);
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 0.85rem;
    color: var(--color-primary);
    letter-spacing: -0.3px;
    word-break: break-all;
    transition: all 0.3s ease;
    font-weight: 500;
  }

  .incorrect-url:hover {
    background: rgba(105, 219, 173, 0.12);
    border-color: rgba(105, 219, 173, 0.25);
    box-shadow: 0 2px 8px rgba(105, 219, 173, 0.1);
  }

  .subheading-404 {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  /* Action cards - horizontal layout with descriptions */
  .action-cards-404 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    width: 100%;
    max-width: 1200px;
  }

  .action-card {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--border-radius-card);
    background: var(--color-surface-container);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .action-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .action-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow:
      0 8px 16px rgba(105, 219, 173, 0.15),
      0 2px 4px rgba(105, 219, 173, 0.08);
  }

  .action-card:hover::before {
    opacity: 0.03;
  }

  .card-icon-wrapper {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(105, 219, 173, 0.2), rgba(105, 219, 173, 0.1));
    transition: all 0.3s ease;
  }

  .action-card:hover .card-icon-wrapper {
    background: linear-gradient(135deg, rgba(105, 219, 173, 0.3), rgba(105, 219, 173, 0.15));
    transform: scale(1.08);
  }

  .card-icon {
    width: 28px;
    height: 28px;
    color: var(--color-primary);
    transition: transform 0.3s ease;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .action-card:hover .card-icon {
    transform: scale(1.1);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
  }

  .action-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-on-surface);
    margin: 0;
    line-height: 1.3;
  }

  .action-card p {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-on-surface-variant);
    margin: 0;
    line-height: 1.4;
  }

  /* Recent memorials section */
  .recent-section-404 {
    width: 100%;
    max-width: 400px;
    animation: fadeInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s backwards;
  }

  .recent-section-404 h2 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-on-surface);
    text-align: center;
    margin: 0 0 1rem;
  }

  .memorial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .memorial-card-compact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: 8px;
    background: var(--color-surface-container-low);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .memorial-card-compact:hover {
    border-color: var(--color-primary);
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgba(105, 219, 173, 0.15);
  }

  .memorial-card-compact h3 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-on-surface);
    margin: 0;
    line-height: 1.3;
  }

  .memorial-date {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-primary);
  }

  /* System status */
  .system-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    animation: fadeIn 1s ease 0.6s backwards;
  }

  .status-indicator {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1.2rem;
  }

  .system-status p {
    margin: 0;
  }

  /* Animations */
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes fallingSand {
    0% {
      transform: translateY(-10px);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(20px);
      opacity: 0;
    }
  }

  /* Mobile responsive */
  @media (max-width: 720px) {
    .not-found-container {
      padding: 1.5rem 1rem;
      gap: 1.5rem;
    }

    .illustration-wrapper {
      width: 200px;
      height: 200px;
      margin: 0 auto 1rem;
    }

    .headline-404 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .url-display {
      margin: 0.75rem 0 0.5rem;
    }

    .incorrect-url {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
    }

    .subheading-404 {
      font-size: 0.9rem;
    }

    .action-cards-404 {
      max-width: 100%;
      gap: 1rem;
      grid-template-columns: 1fr;
    }

    .action-card {
      padding: 1.25rem;
      gap: 0.75rem;
    }

    .card-icon-wrapper {
      width: 48px;
      height: 48px;
    }

    .card-icon {
      width: 24px;
      height: 24px;
    }

    .action-card h3 {
      font-size: 0.95rem;
    }

    .action-card p {
      font-size: 0.85rem;
    }

    .recent-section-404 {
      max-width: 360px;
    }

    .recent-section-404 h2 {
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .memorial-grid {
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .memorial-card-compact {
      padding: 0.6rem;
    }

    .memorial-card-compact h3 {
      font-size: 0.85rem;
    }

    .memorial-date {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .not-found-container {
      padding: 1rem 0.75rem;
      gap: 1.25rem;
    }

    .illustration-wrapper {
      width: 160px;
      height: 160px;
      margin: 0 auto 0.75rem;
    }

    .headline-404 {
      font-size: 1.3rem;
      margin-bottom: 0.4rem;
    }

    .url-display {
      margin: 0.6rem 0 0.4rem;
    }

    .incorrect-url {
      padding: 0.35rem 0.7rem;
      font-size: 0.75rem;
      max-width: 100%;
    }

    .subheading-404 {
      font-size: 0.85rem;
      line-height: 1.4;
    }

    .action-cards-404 {
      max-width: 100%;
      gap: 0.75rem;
      grid-template-columns: 1fr;
    }

    .action-card {
      padding: 1rem;
      gap: 0.75rem;
    }

    .card-icon-wrapper {
      width: 44px;
      height: 44px;
    }

    .card-icon {
      width: 22px;
      height: 22px;
    }

    .action-card h3 {
      font-size: 0.9rem;
    }

    .action-card p {
      font-size: 0.8rem;
      line-height: 1.3;
    }

    .recent-section-404 {
      max-width: 100%;
    }

    .recent-section-404 h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .memorial-grid {
      gap: 0.4rem;
      margin-bottom: 0.75rem;
    }

    .memorial-card-compact {
      padding: 0.5rem;
    }

    .memorial-card-compact h3 {
      font-size: 0.8rem;
    }

    .memorial-date {
      font-size: 0.7rem;
    }

    .system-status {
      font-size: 0.85rem;
      gap: 0.5rem;
    }

    .status-indicator {
      font-size: 1rem;
    }
  }
</style>

<script>
  import { initComingSoonInterceptor } from '@/scripts/comingSoonInterceptor';
  import { initLastRiteToastInterceptor } from '@/scripts/lastRiteToastInterceptor';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initComingSoonInterceptor();
      initLastRiteToastInterceptor();
    });
  } else {
    initComingSoonInterceptor();
    initLastRiteToastInterceptor();
  }
</script>
