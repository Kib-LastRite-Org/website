---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { getCollection } from 'astro:content';
import NotFoundIllustration from '../components/NotFoundIllustration.astro';

// Set proper HTTP status code for SSR
Astro.response.status = 404;
Astro.response.statusText = 'Not Found';

const recentMemorials = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
).slice(0, 3);
---

<MarketingLayout title="404 - Page Not Found" description="The page you're looking for has drifted away, but your memories remain.">
  <main class="not-found-container">
    <!-- Hero section with illustration -->
    <section class="hero-404" data-fade-in>
      <div class="illustration-wrapper">
        <NotFoundIllustration />
      </div>

      <h1 class="headline-404">Page Not Found</h1>
      <p class="subheading-404">
        The page you're looking for doesn't exist. Let's get you back on track.
      </p>
    </section>

    <!-- Quick action cards - compact 2x2 grid -->
    <section class="action-cards-404">
      <a href="/" class="action-card-compact">
        <span class="card-icon">🏠</span>
        <h3>Home</h3>
      </a>
      <a href="/blog" class="action-card-compact">
        <span class="card-icon">📖</span>
        <h3>Memorials</h3>
      </a>
      <a href="/?section=waitlist" class="action-card-compact coming-soon" data-coming-soon>
        <span class="card-icon">📬</span>
        <h3>Join</h3>
      </a>
      <a href="/#contact" class="action-card-compact">
        <span class="card-icon">💬</span>
        <h3>Support</h3>
      </a>
    </section>

    <!-- Recent memorials preview - horizontal scroll on mobile, grid on desktop -->
    {recentMemorials.length > 0 && (
      <section class="recent-section-404">
        <h2>Recent Memorials</h2>
        <div class="memorial-grid">
          {recentMemorials.map((post) => (
            <a href={`/blog/${post.id}/`} class="memorial-card-compact">
              <h3>{post.data.title}</h3>
              <time class="memorial-date">{post.data.pubDate.toLocaleDateString()}</time>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- System status -->
    <div class="system-status">
      <span class="status-indicator">✓</span>
      <p>All systems operational</p>
    </div>
  </main>
</MarketingLayout>

<style>
  .not-found-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    gap: 2rem;
    background: linear-gradient(
      135deg,
      var(--color-background) 0%,
      var(--color-surface-container) 100%
    );
  }

  /* Hero section */
  .hero-404 {
    text-align: center;
    max-width: 500px;
    animation: fadeInDown 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .illustration-wrapper {
    margin: 0 auto 1.5rem;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .illustration-404 {
    width: 100%;
    height: 100%;
    animation: float 4s cubic-bezier(0.4, 0.0, 0.2, 1) infinite;
    filter: drop-shadow(0 8px 16px rgba(105, 219, 173, 0.15));
  }

  .headline-404 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-on-surface);
    margin: 0 0 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  .subheading-404 {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
  }

  /* Action cards - compact 2x2 grid */
  .action-cards-404 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 400px;
  }

  .action-card-compact {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--border-radius-card);
    background: var(--color-surface-container);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .action-card-compact::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .action-card-compact:hover {
    transform: translateY(-6px);
    border-color: var(--color-primary);
    box-shadow:
      0 10px 20px rgba(105, 219, 173, 0.2),
      0 2px 4px rgba(105, 219, 173, 0.1);
  }

  .action-card-compact:hover::before {
    opacity: 0.05;
  }

  .card-icon {
    font-size: 2rem;
    display: block;
    transition: transform 0.3s ease;
  }

  .action-card-compact:hover .card-icon {
    transform: scale(1.15);
  }

  .action-card-compact h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-on-surface);
    margin: 0;
  }

  /* Recent memorials section */
  .recent-section-404 {
    width: 100%;
    max-width: 400px;
    animation: fadeInUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s backwards;
  }

  .recent-section-404 h2 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-on-surface);
    text-align: center;
    margin: 0 0 1rem;
  }

  .memorial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .memorial-card-compact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    border: 1px solid var(--color-outline-variant);
    border-radius: 8px;
    background: var(--color-surface-container-low);
    color: inherit;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .memorial-card-compact:hover {
    border-color: var(--color-primary);
    transform: translateX(4px);
    box-shadow: 0 4px 12px rgba(105, 219, 173, 0.15);
  }

  .memorial-card-compact h3 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-on-surface);
    margin: 0;
    line-height: 1.3;
  }

  .memorial-date {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-primary);
  }

  /* System status */
  .system-status {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    animation: fadeIn 1s ease 0.6s backwards;
  }

  .status-indicator {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1.2rem;
  }

  .system-status p {
    margin: 0;
  }

  /* Animations */
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes fallingSand {
    0% {
      transform: translateY(-10px);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(20px);
      opacity: 0;
    }
  }

  /* Mobile responsive */
  @media (max-width: 720px) {
    .not-found-container {
      padding: 1.5rem 1rem;
      gap: 1.5rem;
    }

    .illustration-wrapper {
      width: 100px;
      height: 100px;
      margin: 0 auto 1rem;
    }

    .headline-404 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }

    .subheading-404 {
      font-size: 0.9rem;
    }

    .action-cards-404 {
      max-width: 360px;
      gap: 0.75rem;
    }

    .action-card-compact {
      padding: 1rem 0.75rem;
    }

    .card-icon {
      font-size: 1.75rem;
    }

    .action-card-compact h3 {
      font-size: 0.9rem;
    }

    .recent-section-404 {
      max-width: 360px;
    }

    .recent-section-404 h2 {
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
    }

    .memorial-grid {
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    .memorial-card-compact {
      padding: 0.6rem;
    }

    .memorial-card-compact h3 {
      font-size: 0.85rem;
    }

    .memorial-date {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .not-found-container {
      padding: 1rem 0.75rem;
      gap: 1.25rem;
    }

    .illustration-wrapper {
      width: 90px;
      height: 90px;
      margin: 0 auto 0.75rem;
    }

    .headline-404 {
      font-size: 1.3rem;
      margin-bottom: 0.4rem;
    }

    .subheading-404 {
      font-size: 0.85rem;
      line-height: 1.4;
    }

    .action-cards-404 {
      max-width: 100%;
      gap: 0.5rem;
    }

    .action-card-compact {
      padding: 0.8rem 0.6rem;
    }

    .card-icon {
      font-size: 1.5rem;
    }

    .action-card-compact h3 {
      font-size: 0.8rem;
    }

    .recent-section-404 {
      max-width: 100%;
    }

    .recent-section-404 h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .memorial-grid {
      gap: 0.4rem;
      margin-bottom: 0.75rem;
    }

    .memorial-card-compact {
      padding: 0.5rem;
    }

    .memorial-card-compact h3 {
      font-size: 0.8rem;
    }

    .memorial-date {
      font-size: 0.7rem;
    }

    .system-status {
      font-size: 0.85rem;
      gap: 0.5rem;
    }

    .status-indicator {
      font-size: 1rem;
    }
  }
</style>

<script>
  import { initComingSoonInterceptor } from '../scripts/comingSoonInterceptor';
  import { initLastRiteToastInterceptor } from '../scripts/lastRiteToastInterceptor';

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initComingSoonInterceptor();
      initLastRiteToastInterceptor();
    });
  } else {
    initComingSoonInterceptor();
    initLastRiteToastInterceptor();
  }
</script>
