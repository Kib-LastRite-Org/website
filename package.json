{
  "name": "lastrite_website",
  "type": "module",
  "version": "0.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro check && astro dev --host",
    "build": "astro check && astro build",
    "dev:build": "astro check && astro build && rm -rf dist && [ ! -d dist ] && echo 'dist folder deleted successfully' || echo 'dist folder still exists'",
    "preview": "astro preview --host",
    "astro": "astro",
    "check": "astro check",
    "clean": "rm -rf dist .astro",
    "build:verbose": "astro build --verbose"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.6",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "idb": "^8.0.3",
    "marked": "^18.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "tiny-markdown-editor": "^0.2.25"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "typescript": "^5.6.0"
  }
}